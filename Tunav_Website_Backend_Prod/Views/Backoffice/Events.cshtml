@{
    ViewData["Title"] = "Gestion des Événements";
    ViewData["ActivePage"] = "Events";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Gestion des Événements</h1>
    <p>Publiez et suivez les événements de l'entreprise (salons, conférences, partenariats)</p>
</div>

<!-- ONGLETS ──────────────────────────────────────────────────────────────── -->
<div class="tab-bar">
    <button class="tab-btn tab-btn--active" id="tabEvents" onclick="switchTab('events')">
         Événements (<span id="eventCount">0</span>)
    </button>
    <button class="tab-btn" id="tabRegistrations" onclick="switchTab('registrations')">
         Inscriptions (<span id="registrationCount">0</span>)
    </button>
</div>

<!-- ── PANEL ÉVÉNEMENTS ───────────────────────────────────────────────────── -->
<div id="panelEvents">
    <div class="card">
        <div class="card-header">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <h2>Liste des événements</h2>
                <select id="filterType" onchange="loadEvents()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                    <option value="">Tous les types</option>
                    <option value="Salon">Salon</option>
                    <option value="Conference">Conférence</option>
                    <option value="Partenariat">Partenariat</option>
                    <option value="Interne">Interne</option>
                    <option value="Autre">Autre</option>
                </select>
                <select id="filterStatus" onchange="loadEvents()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                    <option value="">Tous les statuts</option>
                    <option value="Draft">Brouillon</option>
                    <option value="Published">Publié</option>
                    <option value="Archived">Archivé</option>
                </select>
            </div>
            <div style="display:flex;gap:8px">
                
                <button class="btn btn-primary btn-sm" onclick="openAddEvent()">+ Ajouter</button>
            </div>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Événement</th>
                    <th>Type</th>
                    <th>Date début</th>
                    <th>Lieu</th>
                    <th>Inscriptions</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="eventsTable">
                <tr class="loading-row"><td colspan="7">Chargement...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── PANEL INSCRIPTIONS ───────────────────────────────────────────────────── -->
<div id="panelRegistrations" style="display:none">
    <div class="card">
        <div class="card-header">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <h2>Inscriptions aux événements</h2>
                <select id="filterRegEvent" onchange="loadRegistrations()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                    <option value="">Tous les événements</option>
                </select>
                <select id="filterRegStatus" onchange="loadRegistrations()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                    <option value="">Tous les statuts</option>
                    <option value="Nouvelle">Nouvelle</option>
                    <option value="Confirmee">Confirmée</option>
                    <option value="Annulee">Annulée</option>
                </select>
            </div>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Participant</th>
                    <th>Événement</th>
                    <th>Téléphone</th>
                    <th>Organisation</th>
                    <th>Message</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="registrationsTable">
                <tr class="loading-row"><td colspan="8">Chargement...</tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── MODAL STATUT INSCRIPTION ─────────────────────────────────────────────── -->
<div class="modal-overlay" id="modalRegStatus">
    <div class="modal-box" style="max-width:440px">
        <button class="modal-close-btn" onclick="closeRegStatus()" title="Fermer">✕</button>
        <h3>Mettre à jour le statut</h3>
        <div class="mfield" style="margin-bottom:14px">
            <label>Statut</label>
            <select id="regStatusSelect"
                style="width:100%;padding:10px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:14px;font-family:inherit;outline:none;color:#1e2d5a">
                <option value="Nouvelle">Nouvelle</option>
                <option value="Confirmee">Confirmée</option>
                <option value="Annulee">Annulée</option>
            </select>
        </div>
        <div class="mfield" style="margin-bottom:14px">
            <label>Note interne (optionnel)</label>
            <textarea id="regNoteInput" rows="3"
                style="width:100%;padding:10px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:14px;font-family:inherit;outline:none;color:#1e2d5a;resize:vertical"
                placeholder="Note visible uniquement en backoffice..."></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeRegStatus()">Annuler</button>
            <button class="btn btn-primary" onclick="saveRegStatus()">Enregistrer</button>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     MODAL — ÉVÉNEMENT
════════════════════════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modalEvent">
    <div class="modal-box modal-box--event">

        <!-- En-tête fixe -->
        <div class="modal-header">
            <button class="modal-close-btn" onclick="closeEventForm()" title="Fermer">✕</button>
            <h3 id="eventModalTitle">Ajouter un événement</h3>
            <button class="modal-close-btn" onclick="closeEventForm()" title="Fermer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <!-- Corps scrollable -->
        <div class="modal-scroll-body">

            <div id="eventFormError"
                 style="display:none;background:#fff0f0;border:1px solid #ffc5c5;color:#d63031;
                        padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px"></div>

            <!-- ── SECTION : Informations générales ── -->
            <div class="form-section">
                <div class="form-section-title"> Informations générales</div>

                <!-- Titre -->
                <div class="mfield" style="margin-bottom:14px">
                    <label>Titre *</label>
                    <input type="text" id="evTitle" placeholder="Ex : CES 2026, Forum Invest, Salon GITEX..." />
                </div>

                <!-- Type + Format -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
                    <div class="mfield">
                        <label>Type *</label>
                        <select id="evType">
                            <option value="Salon">Salon</option>
                            <option value="Conference">Conférence</option>
                            <option value="Partenariat">Partenariat</option>
                            <option value="Interne">Interne</option>
                            <option value="Autre">Autre</option>
                        </select>
                    </div>
                    <div class="mfield">
                        <label>Format *</label>
                        <select id="evFormat" onchange="onFormatChange()">
                            <option value="Presentiel"> Présentiel</option>
                            <option value="EnLigne">En ligne</option>
                            <option value="Hybride">Hybride (présentiel + en ligne)</option>
                        </select>
                    </div>
                </div>

                <!-- Description -->
                <div class="mfield">
                    <label>Description</label>
                    <textarea id="evDescription" rows="4"
                        placeholder="Description de l'événement, programme, intervenants..."></textarea>
                </div>
            </div>

            <!-- ── SECTION : Lieu & Participants ── -->
            <div class="form-section">
                <div class="form-section-title"> Lieu & Participants</div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:0">
                    <div class="mfield" id="evLocationField">
                        <label id="evLocationLabel">Lieu physique</label>
                        <input type="text" id="evLocation" placeholder="Ex : Tunis, Paris, Centre de congrès..." />
                    </div>
                    <div class="mfield" id="evOnlineLinkField" style="display:none">
                        <label>Lien de connexion <span style="color:#b0bdd8;font-weight:400">(optionnel)</span></label>
                        <input type="text" id="evOnlineLink" placeholder="https://zoom.us/..." />
                    </div>
                    <div class="mfield">
                        <label>Participants attendus <span style="color:#b0bdd8;font-weight:400">(optionnel)</span></label>
                        <input type="number" id="evParticipants" min="0" placeholder="Ex : 150" />
                    </div>
                </div>
            </div>

            <!-- ── SECTION : Dates ── -->
            <div class="form-section">
                <div class="form-section-title"> Dates & Horaires</div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div class="mfield">
                        <label>Date de début *</label>
                        <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center">
                            <input type="date" id="evStartDateD" />
                            <input type="time" id="evStartDateT" style="width:110px" />
                        </div>
                    </div>
                    <div class="mfield">
                        <label>Date de fin <span style="color:#b0bdd8;font-weight:400">(optionnel)</span></label>
                        <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center">
                            <input type="date" id="evEndDateD" />
                            <input type="time" id="evEndDateT" style="width:110px" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── SECTION : Médias & Liens ── -->
            <div class="form-section">
                <div class="form-section-title"> Médias & Liens</div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
                    <div class="mfield">
                        <label>Image de couverture (URL) <span style="color:#b0bdd8;font-weight:400">(optionnel)</span></label>
                        <input type="text" id="evCoverImageUrl" placeholder="https://..." />
                    </div>
                    <div class="mfield">
                        <label>Vidéo YouTube <span style="color:#b0bdd8;font-weight:400">(optionnel)</span></label>
                        <input type="text" id="evYoutubeUrl" placeholder="https://youtu.be/... ou ID seul" oninput="previewEvYoutube(this.value)" />
                    </div>
                </div>

                <div id="evYoutubePreview" style="display:none;margin-bottom:14px">
                    <label style="font-size:12px;font-weight:500;color:#6b7db3;display:block;margin-bottom:6px">Aperçu vidéo</label>
                    <div style="position:relative;padding-bottom:40%;height:0;border-radius:10px;overflow:hidden;background:#000">
                        <iframe id="evYoutubeFrame" style="position:absolute;top:0;left:0;width:100%;height:100%;border:0" allowfullscreen></iframe>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div class="mfield">
                        <label style="display:flex;align-items:center;gap:5px">
                            Lien externe
                            <span style="color:#b0bdd8;font-weight:400">(optionnel)</span>
                            <span class="ev-tooltip" title="URL du site officiel de l'événement (ex : site d'un salon, page d'inscription). Permet aux visiteurs d'accéder à plus d'informations sur un site tiers.">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#b0bdd8" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            </span>
                        </label>
                        <input type="text" id="evExternalUrl" placeholder="https://gitex.com..." />
                    </div>
                    <div class="mfield" id="evStatusField" style="display:none">
                        <label>Statut</label>
                        <select id="evStatus">
                            <option value="Draft">Brouillon</option>
                            <option value="Published">Publié</option>
                            <option value="Archived">Archivé</option>
                        </select>
                    </div>
                </div>
            </div>

            <div id="evPublishWrapper" style="display:flex;align-items:center;gap:8px;padding:4px 0 8px">
                <input type="checkbox" id="evPublish" style="width:auto;accent-color:#00c8d4" />
                <label for="evPublish" style="font-size:13px;font-weight:500;color:#1e2d5a;cursor:pointer;margin:0">
                    Publier immédiatement
                </label>
            </div>

        </div>

        <div class="modal-sticky-footer">
            <button class="btn btn-outline" onclick="closeEventForm()">Annuler</button>
            <button class="btn btn-primary" id="btnSaveEvent" onclick="saveEvent()">Enregistrer</button>
        </div>

    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     MODAL — SUPPRESSION
════════════════════════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modalDelete">
    <div class="modal-box" style="max-width:400px;text-align:center">
        <button class="modal-close-btn" onclick="closeDelete()" title="Fermer">✕</button>
        <h3 style="margin-bottom:8px">Confirmer la suppression</h3>
        <p style="font-size:14px;color:#6b7db3;margin-bottom:24px" id="deleteMsg">
            Cette action est irréversible.
        </p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">Supprimer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .modal-close-btn { position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:#6b7db3; line-height:1; padding:4px 8px; border-radius:6px; transition:background 0.2s; }
    .modal-close-btn:hover { background:#f0f4ff; color:#1e2d5a; }
    .modal-box { position:relative; }
    .tab-bar {
        display:flex;gap:8px;margin-bottom:20px;
        border-bottom:2px solid #e8edf8;padding-bottom:0;
    }
    .tab-btn {
        background:none;border:none;padding:10px 20px;
        font-size:14px;font-weight:500;color:#6b7db3;
        cursor:pointer;border-bottom:2px solid transparent;
        margin-bottom:-2px;transition:color .2s,border-color .2s;
    }
    .tab-btn--active { color:#00c8d4;border-bottom-color:#00c8d4; }
    .tab-btn:hover:not(.tab-btn--active) { color:#1e2d5a; }

    .mfield label {
        display:block;font-size:12px;font-weight:500;
        color:#6b7db3;margin-bottom:5px;
    }
    .mfield input[type="time"] {
        padding:10px 8px;
        border:1.5px solid #dce4f5;border-radius:8px;
        font-size:14px;font-family:'Inter',sans-serif;
        outline:none;color:#1e2d5a;
        transition:border-color .2s;background:white;
    }
    .mfield input[type="time"]:focus { border-color:#00c8d4; }
    .mfield input[type="date"] {
        padding:10px 12px;
        border:1.5px solid #dce4f5;border-radius:8px;
        font-size:14px;font-family:'Inter',sans-serif;
        outline:none;color:#1e2d5a;
        transition:border-color .2s;background:white;width:100%;
    }
    .mfield input[type="date"]:focus { border-color:#00c8d4; }

    .ev-tooltip {
        cursor:help;display:inline-flex;align-items:center;
        position:relative;
    }
    .ev-tooltip:hover::after {
        content: attr(title);
        position:absolute;bottom:calc(100% + 6px);left:50%;
        transform:translateX(-50%);
        background:#1e2d5a;color:#fff;
        font-size:11px;font-weight:400;
        padding:6px 10px;border-radius:6px;
        white-space:nowrap;max-width:260px;white-space:normal;
        z-index:999;line-height:1.4;
        box-shadow:0 4px 12px rgba(0,0,0,.15);
    }

    .mfield input,.mfield textarea,.mfield select {
        width:100%;padding:10px 12px;
        border:1.5px solid #dce4f5;border-radius:8px;
        font-size:14px;font-family:'Inter',sans-serif;
        outline:none;color:#1e2d5a;
        transition:border-color .2s;background:white;
    }
    .mfield input:focus,.mfield textarea:focus,.mfield select:focus { border-color:#00c8d4; }
    .mfield textarea { resize:vertical; }

    .badge-type {
        font-size:11px;font-weight:600;padding:3px 8px;border-radius:6px;
        display:inline-block;
    }
    .badge-type-salon      { background:#e0f7fa;color:#006064; }
    .badge-type-conference { background:#f3e5f5;color:#6a1b9a; }
    .badge-type-partenariat{ background:#fff3e0;color:#e65100; }
    .badge-type-interne    { background:#e8f5e9;color:#2e7d32; }
    .badge-type-autre      { background:#f5f5f5;color:#424242; }

    .ev-thumb {
        width:60px;height:40px;object-fit:cover;
        border-radius:6px;flex-shrink:0;
    }
    .ev-placeholder {
        width:60px;height:40px;border-radius:6px;
        background:#e8edf8;display:flex;
        align-items:center;justify-content:center;
        font-size:20px;flex-shrink:0;
    }

    .status-draft     { background:#f5f5f5;color:#757575; }
    .status-published { background:#e8f5e9;color:#2e7d32; }
    .status-archived  { background:#fff3e0;color:#e65100; }

    .modal-box--event {
        max-width:760px;
        display:flex;
        flex-direction:column;
        max-height:90vh;
        padding:0 !important;
        overflow:hidden;
    }

    .modal-header {
        display:flex;align-items:center;justify-content:space-between;
        padding:18px 24px;
        border-bottom:1.5px solid #e8edf8;
        flex-shrink:0;
        background:#fff;
        border-radius:12px 12px 0 0;
    }
    .modal-header h3 {
        font-size:17px;font-weight:700;color:#1e2d5a;margin:0;
    }
    .modal-close-btn {
        width:32px;height:32px;border-radius:8px;
        border:1.5px solid #dce4f5;background:#fff;
        cursor:pointer;color:#6b7db3;
        display:flex;align-items:center;justify-content:center;
        transition:all .15s;flex-shrink:0;
    }
    .modal-close-btn:hover { background:#f0f4ff;color:#1e2d5a; }

    .modal-scroll-body {
        flex:1;
        overflow-y:auto;
        padding:20px 24px;
        display:flex;
        flex-direction:column;
        gap:0;
    }

    .form-section {
        border:1.5px solid #e8edf8;
        border-radius:10px;
        padding:16px 18px;
        margin-bottom:14px;
        background:#fafbff;
    }
    .form-section-title {
        font-size:12px;font-weight:700;
        color:#6b7db3;text-transform:uppercase;
        letter-spacing:.6px;margin-bottom:14px;
    }
    .form-section .mfield:last-child { margin-bottom:0 !important; }

    .modal-sticky-footer {
        display:flex;justify-content:flex-end;gap:10px;
        padding:14px 24px;
        border-top:1.5px solid #e8edf8;
        background:#fff;
        flex-shrink:0;
        border-radius:0 0 12px 12px;
    }
</style>

<script>
    let editingEventId  = null;
    let deletingId      = null;
    let deleteType      = null;
    let allEvents       = [];

    function switchTab(tab) {
        document.getElementById('panelEvents').style.display = tab === 'events' ? '' : 'none';
        document.getElementById('panelRegistrations').style.display = tab === 'registrations' ? '' : 'none';
        document.getElementById('tabEvents').classList.toggle('tab-btn--active', tab === 'events');
        document.getElementById('tabRegistrations').classList.toggle('tab-btn--active', tab === 'registrations');
        if (tab === 'registrations') loadRegistrations();
    }

    function onFormatChange() {
        const fmt = document.getElementById('evFormat').value;
        const physField   = document.getElementById('evLocationField');
        const onlineField = document.getElementById('evOnlineLinkField');
        const physLabel   = document.getElementById('evLocationLabel');

        if (fmt === 'Presentiel') {
            physField.style.display = '';
            onlineField.style.display = 'none';
            physLabel.textContent = 'Lieu physique';
        } else if (fmt === 'EnLigne') {
            physField.style.display = 'none';
            onlineField.style.display = '';
        } else {
            physField.style.display = '';
            onlineField.style.display = '';
            physLabel.textContent = 'Lieu physique';
        }
    }

    function extractYtId(val) {
        if (!val) return null;
        val = val.trim();
        if (val.includes('youtu.be/')) return val.split('youtu.be/').pop().split('?')[0];
        if (val.includes('v=')) return val.split('v=').pop().split('&')[0];
        return val.length <= 20 ? val : null;
    }

    function previewEvYoutube(val) {
        const id = extractYtId(val);
        const box = document.getElementById('evYoutubePreview');
        if (id) {
            document.getElementById('evYoutubeFrame').src = 'https://www.youtube-nocookie.com/embed/' + id;
            box.style.display = 'block';
        } else {
            box.style.display = 'none';
            document.getElementById('evYoutubeFrame').src = '';
        }
    }

    function typeBadge(type) {
        const map = {
            'Salon':'badge-type-salon','Conference':'badge-type-conference',
            'Partenariat':'badge-type-partenariat','Interne':'badge-type-interne','Autre':'badge-type-autre'
        };
        return `<span class="badge-type ${map[type]||'badge-type-autre'}">${type}</span>`;
    }

    function statusBadge(status) {
        const map = {
            'Draft':'status-draft  Brouillon',
            'Published':'status-published  Publié',
            'Archived':'status-archived  Archivé'
        };
        const [cls, ...label] = (map[status]||'status-draft 📝').split(' ');
        return `<span class="badge ${cls}">${label.join(' ')}</span>`;
    }

    function fmtDate(d) {
        if (!d) return '—';
        return new Date(d).toLocaleDateString('fr-FR', {day:'2-digit',month:'short',year:'numeric'});
    }

    async function loadEvents() {
        const type   = document.getElementById('filterType').value;
        const status = document.getElementById('filterStatus').value;
        let url = '/api/events';
        const params = [];
        if (type) params.push('type=' + type);
        if (status) params.push('status=' + status);
        if (params.length) url += '?' + params.join('&');

        try {
            const res = await fetch(url, { headers: authHeaders() });
            const list = await res.json();
            allEvents = Array.isArray(list) ? list : [];
            document.getElementById('eventCount').textContent = allEvents.length;

            document.getElementById('eventsTable').innerHTML = allEvents.length
                ? allEvents.map(e => `
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                ${e.coverImageUrl ? `<img src="${e.coverImageUrl}" class="ev-thumb" onerror="this.style.display='none'" />` : `<div class="ev-placeholder">📅</div>`}
                                <div>
                                    <div style="font-weight:600;color:#1e2d5a;max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${e.title}</div>
                                    ${e.location ? `<div style="font-size:11px;color:#6b7db3">📍 ${e.location}</div>` : ''}
                                </div>
                            </div>
                        </td>
                        <td>${typeBadge(e.type)}</td>
                        <td style="font-size:13px;color:#1e2d5a;white-space:nowrap">
                            ${fmtDate(e.startDate)}
                            ${e.endDate ? `<div style="font-size:11px;color:#6b7db3">→ ${fmtDate(e.endDate)}</div>` : ''}
                        </td>
                        <td style="font-size:13px;color:#6b7db3">${e.location || '—'}</td>
                        <td style="text-align:center"><span class="badge badge-cyan" style="cursor:pointer" onclick="switchTab('registrations');document.getElementById('filterRegEvent').value=${e.id};loadRegistrations()">${e.registrationCount || 0}</span></td>
                        <td>${statusBadge(e.status)}</td>
                        <td>
                            <div style="display:flex;gap:5px;flex-wrap:wrap">
                                <button class="btn btn-outline btn-sm" onclick="openEditEvent(${e.id})">Modifier</button>
                                <button class="btn btn-outline btn-sm" style="${e.status === 'Published' ? 'border-color:#ffc107;color:#856404' : 'border-color:#00b894;color:#00704a'}" onclick="toggleEvent(${e.id})">${e.status === 'Published' ? 'Dépublier' : 'Publier'}</button>
                                <button class="btn btn-danger btn-sm" onclick="openDelete('event',${e.id},'${e.title.replace(/'/g,"\\'")}')">Supprimer</button>
                            </div>
                        </td>
                    </tr>
                `).join('')
                : '<tr class="empty-row"><td colspan="7">Aucun événement trouvé.</td></tr>';
        } catch(e) {
            document.getElementById('eventsTable').innerHTML = '<tr class="empty-row"><td colspan="7">Erreur de chargement.</td></tr>';
        }
    }

    function openAddEvent() {
        editingEventId = null;
        document.getElementById('eventModalTitle').textContent = 'Ajouter un événement';
        document.getElementById('btnSaveEvent').textContent = 'Enregistrer';
        ['evTitle','evLocation','evOnlineLink','evCoverImageUrl','evYoutubeUrl','evExternalUrl','evDescription'].forEach(id => document.getElementById(id).value = '');
        document.getElementById('evParticipants').value = '';
        document.getElementById('evType').value = 'Autre';
        document.getElementById('evFormat').value = 'Presentiel';
        document.getElementById('evStartDateD').value = '';
        document.getElementById('evStartDateT').value = '';
        document.getElementById('evEndDateD').value = '';
        document.getElementById('evEndDateT').value = '';
        document.getElementById('evPublish').checked = false;
        document.getElementById('evPublishWrapper').style.display = 'flex';
        document.getElementById('evStatusField').style.display = 'none';
        document.getElementById('eventFormError').style.display = 'none';
        document.getElementById('evYoutubePreview').style.display = 'none';
        document.getElementById('evYoutubeFrame').src = '';
        onFormatChange();
        document.getElementById('modalEvent').classList.add('show');
    }

    async function openEditEvent(id) {
        editingEventId = id;
        document.getElementById('eventFormError').style.display = 'none';
        document.getElementById('eventModalTitle').textContent = 'Modifier un événement';
        document.getElementById('btnSaveEvent').textContent = 'Mettre à jour';

        try {
            const res = await fetch('/api/events/' + id, { headers: authHeaders() });
            const ev = await res.json();

            document.getElementById('evTitle').value = ev.title || '';
            document.getElementById('evDescription').value = ev.description || '';
            document.getElementById('evLocation').value = ev.location || '';
            document.getElementById('evCoverImageUrl').value = ev.coverImageUrl || '';
            document.getElementById('evYoutubeUrl').value = ev.youtubeUrl || '';
            document.getElementById('evExternalUrl').value = ev.externalUrl || '';
            document.getElementById('evType').value = ev.type || 'Autre';
            document.getElementById('evStatus').value = ev.status || 'Draft';
            document.getElementById('evParticipants').value = ev.participantCount || '';
            document.getElementById('evStatusField').style.display = 'block';
            document.getElementById('evPublishWrapper').style.display = 'none';

            const loc = (ev.location || '').toLowerCase();
            let fmt = 'Presentiel';
            if (ev.onlineLink || loc.includes('zoom') || loc.includes('meet') || loc.includes('teams') || loc.includes('en ligne')) fmt = 'EnLigne';
            document.getElementById('evFormat').value = fmt;
            document.getElementById('evOnlineLink').value = ev.onlineLink || '';
            onFormatChange();

            const pad = n => String(n).padStart(2,'0');
            const splitDt = d => {
                if (!d) return ['', ''];
                const dt = new Date(d);
                return [`${dt.getFullYear()}-${pad(dt.getMonth()+1)}-${pad(dt.getDate())}`, `${pad(dt.getHours())}:${pad(dt.getMinutes())}`];
            };
            const [sd, st] = splitDt(ev.startDate);
            const [ed, et] = splitDt(ev.endDate);
            document.getElementById('evStartDateD').value = sd;
            document.getElementById('evStartDateT').value = st;
            document.getElementById('evEndDateD').value = ed;
            document.getElementById('evEndDateT').value = et;

            previewEvYoutube(ev.youtubeUrl);
            document.getElementById('modalEvent').classList.add('show');
        } catch(e) { alert("Erreur lors du chargement de l'événement."); }
    }

    function closeEventForm() {
        document.getElementById('modalEvent').classList.remove('show');
        document.getElementById('evYoutubePreview').style.display = 'none';
        document.getElementById('evYoutubeFrame').src = '';
        editingEventId = null;
    }

    async function saveEvent() {
        const btn = document.getElementById('btnSaveEvent');
        document.getElementById('eventFormError').style.display = 'none';

        const title = document.getElementById('evTitle').value.trim();
        const description = document.getElementById('evDescription').value.trim();
        const type = document.getElementById('evType').value;
        const format = document.getElementById('evFormat').value;
        const coverImageUrl = document.getElementById('evCoverImageUrl').value.trim();
        const youtubeUrl = document.getElementById('evYoutubeUrl').value.trim();
        const externalUrl = document.getElementById('evExternalUrl').value.trim();
        const participants = parseInt(document.getElementById('evParticipants').value) || null;

        const locationPhys = document.getElementById('evLocation').value.trim();
        const locationOnline = document.getElementById('evOnlineLink').value.trim();
        let location = '';
        if (format === 'Presentiel') location = locationPhys;
        else if (format === 'EnLigne') location = locationOnline || 'En ligne';
        else location = [locationPhys, locationOnline].filter(Boolean).join(' / ') || 'Hybride';

        const startD = document.getElementById('evStartDateD').value;
        const startT = document.getElementById('evStartDateT').value || '00:00';
        const endD = document.getElementById('evEndDateD').value;
        const endT = document.getElementById('evEndDateT').value || '00:00';

        if (!title) { showEventErr('Le titre est obligatoire.'); return; }
        if (!startD) { showEventErr('La date de début est obligatoire.'); return; }

        const startDate = new Date(`${startD}T${startT}`).toISOString();
        const endDate = endD ? new Date(`${endD}T${endT}`).toISOString() : null;

        btn.disabled = true; btn.textContent = 'Enregistrement...';

        try {
            let url, method, body;
            if (editingEventId) {
                const status = document.getElementById('evStatus').value;
                url = '/api/events/' + editingEventId;
                method = 'PUT';
                body = { title, description: description || null, type, startDate, endDate, location: location || null, coverImageUrl: coverImageUrl || null, youtubeUrl: youtubeUrl || null, externalUrl: externalUrl || null, status, participantCount: participants };
            } else {
                const u = JSON.parse(localStorage.getItem('tunav_user') || '{}');
                const publish = document.getElementById('evPublish').checked;
                url = '/api/events?userId=' + (u.userId || 1);
                method = 'POST';
                body = { title, description: description || null, type, startDate, endDate, location: location || null, coverImageUrl: coverImageUrl || null, youtubeUrl: youtubeUrl || null, externalUrl: externalUrl || null, publish, participantCount: participants };
            }

            const res = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(body) });
            const data = await res.json();
            if (res.ok) { closeEventForm(); loadEvents(); }
            else showEventErr(data.message || "Erreur lors de l'enregistrement.");
        } catch(e) { showEventErr('Erreur réseau.'); }
        finally { btn.disabled = false; btn.textContent = editingEventId ? 'Mettre à jour' : 'Enregistrer'; }
    }

    function showEventErr(msg) {
        const el = document.getElementById('eventFormError');
        el.textContent = msg; el.style.display = 'block';
    }

    async function toggleEvent(id) {
        try {
            const res = await fetch('/api/events/' + id + '/toggle', { method: 'PATCH', headers: authHeaders() });
            if (res.ok) loadEvents();
        } catch(e) { alert('Erreur réseau.'); }
    }

    async function archiveExpired() {
        try {
            const res = await fetch('/api/events/archive-expired', { method: 'POST', headers: authHeaders() });
            const data = await res.json();
            alert(data.message || 'Archivage effectué.');
            loadEvents();
        } catch(e) { alert('Erreur réseau.'); }
    }

    function openDelete(type, id, label) {
        deleteType = type; deletingId = id;
        document.getElementById('deleteMsg').textContent = 'Voulez-vous vraiment supprimer "' + label + '" ? Cette action est irréversible.';
        document.getElementById('modalDelete').classList.add('show');
    }

    function closeDelete() {
        document.getElementById('modalDelete').classList.remove('show');
        deletingId = null; deleteType = null;
    }

    async function confirmDelete() {
        if (!deletingId || !deleteType) return;
        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled = true; btn.textContent = 'Suppression...';
        try {
            const url = deleteType === 'event' ? '/api/events/' + deletingId : '/api/collaborations/' + deletingId;
            const res = await fetch(url, { method: 'DELETE', headers: authHeaders() });
            if (res.ok || res.status === 204) {
                closeDelete();
                if (deleteType === 'event') loadEvents();
            } else { alert('Erreur lors de la suppression.'); }
        } catch(e) { alert('Erreur réseau.'); }
        finally { btn.disabled = false; btn.textContent = 'Supprimer'; }
    }

    let editingRegId = null;

    async function loadRegistrations() {
        const evId = document.getElementById('filterRegEvent').value;
        const status = document.getElementById('filterRegStatus').value;
        let url = '/api/registrations';
        const params = [];
        if (evId) params.push('eventId=' + evId);
        if (status) params.push('status=' + encodeURIComponent(status));
        if (params.length) url += '?' + params.join('&');

        try {
            const res = await fetch(url, { headers: authHeaders() });
            if (!res.ok) { document.getElementById('registrationsTable').innerHTML = '<tr class="empty-row"><td colspan="8">Erreur ' + res.status + '</td><tr>'; return; }
            const list = await res.json();
            const regs = Array.isArray(list) ? list : [];
            document.getElementById('registrationCount').textContent = regs.length;

            document.getElementById('registrationsTable').innerHTML = regs.length
                ? regs.map(r => {
                    const badgeMap = { Nouvelle:'badge-navy', Confirmee:'badge-success', Annulee:'badge-danger' };
                    const labelMap = { Nouvelle:'Nouvelle', Confirmee:'Confirmée', Annulee:'Annulée' };
                    return `<tr>
                        <td><div style="font-weight:600;color:#1e2d5a">${esc(r.fullName)}</div><div style="font-size:12px;color:#6b7db3"><a href="mailto:${esc(r.email)}" style="color:#00c8d4">${esc(r.email)}</a></div></td>
                        <td><span class="badge badge-cyan" style="font-size:11px">${esc(r.eventTitle)}</span></td>
                        <td style="font-size:13px;color:#1e2d5a">${r.phone || '—'}</td>
                        <td style="font-size:13px;color:#6b7db3">${r.organization || '—'}</td>
                        <td style="font-size:12px;color:#6b7db3;max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${(r.message||'').replace(/"/g,'&quot;')}">${r.message || '—'}</td>
                        <td style="font-size:12px;color:#6b7db3;white-space:nowrap">${fmtDate(r.registeredAt)}</td>
                        <td><span class="badge ${badgeMap[r.status]||'badge-navy'}">${labelMap[r.status]||r.status}</span></td>
                        <td><div style="display:flex;gap:6px;flex-wrap:wrap"><button class="btn btn-outline btn-sm" onclick="openRegStatus(${r.id},'${r.status}','${(r.internalNote||'').replace(/'/g,"\'")}')">Statut</button><button class="btn btn-danger btn-sm" onclick="deleteRegistration(${r.id})">Supprimer</button></div></td>
                    </tr>`;
                }).join('')
                : '<tr class="empty-row"><td colspan="8">Aucune inscription trouvée. </tr>';
        } catch(e) {
            document.getElementById('registrationsTable').innerHTML = '<tr class="empty-row"><td colspan="8">Erreur de chargement. </tr>';
        }
    }

    function openRegStatus(id, status, note) {
        editingRegId = id;
        document.getElementById('regStatusSelect').value = status;
        document.getElementById('regNoteInput').value = note;
        document.getElementById('modalRegStatus').classList.add('show');
    }

    function closeRegStatus() {
        document.getElementById('modalRegStatus').classList.remove('show');
        editingRegId = null;
    }

    async function saveRegStatus() {
        if (!editingRegId) return;
        const status = document.getElementById('regStatusSelect').value;
        const note = document.getElementById('regNoteInput').value.trim();
        try {
            const res = await fetch('/api/registrations/' + editingRegId + '/status', {
                method: 'PATCH', headers: authHeaders(),
                body: JSON.stringify({ status, internalNote: note || null })
            });
            if (res.ok) { closeRegStatus(); loadRegistrations(); }
            else alert('Erreur lors de la mise à jour.');
        } catch(e) { alert('Erreur réseau.'); }
    }

    async function deleteRegistration(id) {
        if (!confirm('Supprimer cette inscription ?')) return;
        try {
            const res = await fetch('/api/registrations/' + id, { method: 'DELETE', headers: authHeaders() });
            if (res.ok || res.status === 204) loadRegistrations();
            else alert('Erreur lors de la suppression.');
        } catch(e) { alert('Erreur réseau.'); }
    }

    function esc(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    (async function init() {
        await loadEvents();
        const regEvSel = document.getElementById('filterRegEvent');
        if (regEvSel && allEvents.length) {
            regEvSel.innerHTML = '<option value="">Tous les événements</option>' + allEvents.map(e => `<option value="${e.id}">${e.title}</option>`).join('');
        }
    })();
</script>
}