@{
    ViewData["Title"] = "Demandes de Demo";
    ViewData["ActivePage"] = "DemoRequests";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Demandes de Demo</h1>
    <p>Gerez les demandes recues depuis la page demo et les modales des solutions.</p>
</div>

<div class="card">
    <div class="card-header">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <h2>Liste des demandes (<span id="requestCount">0</span>)</h2>
            <select id="filterSolution" onchange="loadDemoRequests()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none;min-width:220px">
                <option value="">Toutes les solutions</option>
            </select>
            <select id="filterStatus" onchange="loadDemoRequests()"
                    style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                <option value="">Tous les statuts</option>
                <option value="Nouvelle">Nouvelle</option>
                <option value="EnCours">En cours</option>
                <option value="Acceptee">Acceptee</option>
                <option value="Refusee">Refusee</option>
            </select>
            <input type="text"
                   id="searchInput"
                   placeholder="Rechercher solution / contact / email..."
                   oninput="applySearch()"
                   style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none;width:260px" />
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Solution</th>
                <th>Nom complet</th>
                <th>Email</th>
                <th>Telephone</th>
                <th>WhatsApp</th>
                <th>Numero WhatsApp</th>
                <th>Point d'entree</th>
                <th>Date de soumission</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="requestsTable">
            <tr class="loading-row"><td colspan="10">Chargement...</td></tr>
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="modalDetail" onclick="if(event.target===this)closeDetail()">
    <div class="modal-box" style="max-width:580px">
        <h3 style="margin-bottom:4px">Detail de la demande</h3>
        <p id="detailSolution" style="font-size:12px;color:#6b7db3;margin-bottom:18px;font-weight:500"></p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div>
                <div class="detail-label">Nom complet</div>
                <div id="detailName" class="detail-value"></div>
            </div>
            <div>
                <div class="detail-label">Email</div>
                <div id="detailEmail" class="detail-value"></div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div>
                <div class="detail-label">Telephone</div>
                <div id="detailPhone" class="detail-value"></div>
            </div>
            <div>
                <div class="detail-label">WhatsApp disponible</div>
                <div id="detailHasWhatsapp" class="detail-value"></div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div>
                <div class="detail-label">Numero WhatsApp</div>
                <div id="detailWhatsappNumber" class="detail-value"></div>
            </div>
            <div>
                <div class="detail-label">Point d'entree</div>
                <div id="detailEntryPoint" class="detail-value"></div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div>
                <div class="detail-label">Soumise le</div>
                <div id="detailSubmittedAt" class="detail-value"></div>
            </div>
        </div>

        <div style="margin-bottom:14px">
            <div class="detail-label">Note interne</div>
            <div id="detailNote" style="font-size:13px;color:#1e2d5a;background:#fffde7;padding:12px;border-radius:8px;border:1px solid #fff59d;white-space:pre-wrap"></div>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid #dce4f5">
            <div id="detailStatusWrap"></div>
            <div style="display:flex;gap:8px">
                <button class="btn btn-outline" onclick="closeDetail()">Fermer</button>
                <button class="btn btn-primary btn-sm" id="btnDetailEditStatus">Modifier le statut</button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalStatus" onclick="if(event.target===this)closeStatus()">
    <div class="modal-box" style="max-width:460px">
        <h3>Mettre a jour la demande</h3>
        <p id="statusInfo" style="font-size:13px;color:#6b7db3;margin-bottom:18px;padding:10px 14px;background:#f8faff;border-radius:8px;border-left:3px solid #00c8d4"></p>
        <div class="mfield" style="margin-bottom:14px">
            <label>Nouveau statut</label>
            <select id="newStatus">
                <option value="Nouvelle">Nouvelle</option>
                <option value="EnCours">En cours</option>
                <option value="Acceptee">Acceptee</option>
                <option value="Refusee">Refusee</option>
            </select>
        </div>
        <div class="mfield" style="margin-bottom:20px">
            <label>Note interne</label>
            <textarea id="noteField" rows="4" placeholder="Ex : prioriser le suivi ou recontacter le prospect..."></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeStatus()">Annuler</button>
            <button class="btn btn-primary" id="btnSaveStatus" onclick="saveStatus()">Enregistrer</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalDelete" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box" style="max-width:400px;text-align:center">
        <h3 style="margin-bottom:8px">Confirmer la suppression</h3>
        <p id="deleteMsg" style="font-size:14px;color:#6b7db3;margin-bottom:24px"></p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">Supprimer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .badge-nouvelle { background: #e3f2fd; color: #1565c0; }
    .badge-encours { background: #fff3e0; color: #e65100; }
    .badge-acceptee { background: #e8f5e9; color: #2e7d32; }
    .badge-refusee { background: #ffebee; color: #c62828; }
    .badge-yes { background: #e8f5e9; color: #2e7d32; }
    .badge-no { background: #eceff1; color: #546e7a; }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .detail-label {
        font-size: 11px;
        font-weight: 600;
        color: #6b7db3;
        margin-bottom: 4px;
    }

    .detail-value {
        font-size: 13px;
        color: #1e2d5a;
        white-space: pre-wrap;
    }
</style>

<script>
    let allRequests = [];
    let editingId = null;
    let deletingId = null;

    const entryPointLabels = {
        DemoPage: 'Page Demo',
        SolutionsList: 'Liste des solutions',
        SolutionDetail: 'Detail solution',
        PacksPage: 'Page Packs'
    };

    function statusBadge(status) {
        const map = {
            'Nouvelle': ['badge-nouvelle', 'Nouvelle'],
            'EnCours': ['badge-encours', 'En cours'],
            'Acceptee': ['badge-acceptee', 'Acceptee'],
            'Refusee': ['badge-refusee', 'Refusee']
        };

        const [cls, label] = map[status] || ['badge-nouvelle', status];
        return `<span class="badge ${cls}">${label}</span>`;
    }

    function yesNoBadge(hasWhatsapp) {
        return hasWhatsapp
            ? '<span class="badge badge-yes">Oui</span>'
            : '<span class="badge badge-no">Non</span>';
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;')
                  .replace(/</g, '&lt;')
                  .replace(/>/g, '&gt;')
                  .replace(/"/g, '&quot;')
                  .replace(/'/g, '&#39;');
    }

    function fmtDate(value) {
        if (!value) return '—';
        return new Date(value).toLocaleDateString('fr-FR', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function getFullName(request) {
        return [request.firstName, request.lastName].filter(Boolean).join(' ') || '—';
    }

    function getSolutionLabel(request) {
        const solutionTitle = request.solutionTitle || '—';
        return request.packName
            ? `${solutionTitle} - ${request.packName}`
            : solutionTitle;
    }

    function renderSolutionOptions(list) {
        const filter = document.getElementById('filterSolution');
        const currentValue = filter.value;
        const uniqueSolutions = [...new Map(
            list
                .filter(request => request.solutionId && request.solutionTitle)
                .map(request => [request.solutionId, {
                    id: request.solutionId,
                    title: request.solutionTitle
                }])
        ).values()].sort((left, right) => left.title.localeCompare(right.title, 'fr', { sensitivity: 'base' }));

        filter.innerHTML = '<option value="">Toutes les solutions</option>' + uniqueSolutions
            .map(solution => `<option value="${solution.id}">${escapeHtml(solution.title)}</option>`)
            .join('');

        if (uniqueSolutions.some(solution => String(solution.id) === currentValue)) {
            filter.value = currentValue;
        }
    }

    async function loadSolutionOptions() {
        try {
            const res = await fetch('/api/demo-requests', { headers: authHeaders() });
            if (!res.ok) return;
            const list = await res.json();
            renderSolutionOptions(Array.isArray(list) ? list : []);
        } catch { }
    }

    async function loadDemoRequests() {
        const solutionId = document.getElementById('filterSolution').value;
        const status = document.getElementById('filterStatus').value;
        const params = [];

        if (solutionId) params.push('solutionId=' + encodeURIComponent(solutionId));
        if (status) params.push('status=' + encodeURIComponent(status));

        const url = '/api/demo-requests' + (params.length ? '?' + params.join('&') : '');
        document.getElementById('requestsTable').innerHTML = '<tr class="loading-row"><td colspan="10">Chargement...</td></tr>';

        try {
            const res = await fetch(url, { headers: authHeaders() });
            if (res.status === 401 || res.status === 403) {
                document.getElementById('requestsTable').innerHTML = '<tr class="empty-row"><td colspan="10">Acces non autorise.</td></tr>';
                return;
            }

            const list = await res.json();
            allRequests = Array.isArray(list) ? list : [];
            renderTable(allRequests);
            document.getElementById('requestCount').textContent = allRequests.length;
        } catch {
            document.getElementById('requestsTable').innerHTML = '<tr class="empty-row"><td colspan="10">Erreur de chargement.</td></tr>';
        }
    }

    function applySearch() {
        const query = document.getElementById('searchInput').value.toLowerCase().trim();
        if (!query) {
            renderTable(allRequests);
            return;
        }

        const filtered = allRequests.filter(request =>
            getFullName(request).toLowerCase().includes(query) ||
            (request.email || '').toLowerCase().includes(query) ||
            (request.phone || '').toLowerCase().includes(query) ||
            (request.solutionTitle || '').toLowerCase().includes(query) ||
            (request.packName || '').toLowerCase().includes(query) ||
            (request.whatsappNumber || '').toLowerCase().includes(query)
        );

        renderTable(filtered);
    }

    function renderTable(list) {
        document.getElementById('requestsTable').innerHTML = list.length ? list.map(request => `
            <tr>
                <td style="font-weight:600">${escapeHtml(getSolutionLabel(request))}</td>
                <td>${escapeHtml(getFullName(request))}</td>
                <td><a href="mailto:${escapeHtml(request.email)}" style="color:#00c8d4">${escapeHtml(request.email)}</a></td>
                <td>${escapeHtml(request.phone || '—')}</td>
                <td>${yesNoBadge(request.hasWhatsapp)}</td>
                <td>${escapeHtml(request.whatsappNumber || '—')}</td>
                <td>${escapeHtml(entryPointLabels[request.entryPoint] || request.entryPoint || '—')}</td>
                <td style="white-space:nowrap">${fmtDate(request.submittedAt)}</td>
                <td>${statusBadge(request.status)}</td>
                <td>
                    <div style="display:flex;gap:5px;flex-wrap:wrap">
                        <button class="btn btn-outline btn-sm" onclick="openDetail(${request.id})">Detail</button>
                        <button class="btn btn-outline btn-sm" style="border-color:#00c8d4;color:#00c8d4" onclick="openStatus(${request.id})">Statut</button>
                        <button class="btn btn-danger btn-sm" onclick="openDelete(${request.id})">Supprimer</button>
                    </div>
                </td>
            </tr>
        `).join('') : '<tr class="empty-row"><td colspan="10">Aucune demande.</td></tr>';
    }

    function openDetail(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        document.getElementById('detailSolution').textContent = 'Solution : ' + getSolutionLabel(request);
        document.getElementById('detailName').textContent = getFullName(request);
        document.getElementById('detailEmail').innerHTML = `<a href="mailto:${escapeHtml(request.email)}" style="color:#00c8d4">${escapeHtml(request.email)}</a>`;
        document.getElementById('detailPhone').textContent = request.phone || '—';
        document.getElementById('detailHasWhatsapp').textContent = request.hasWhatsapp ? 'Oui' : 'Non';
        document.getElementById('detailWhatsappNumber').textContent = request.whatsappNumber || '—';
        document.getElementById('detailEntryPoint').textContent = entryPointLabels[request.entryPoint] || request.entryPoint || '—';
        document.getElementById('detailSubmittedAt').textContent = fmtDate(request.submittedAt);
        document.getElementById('detailNote').textContent = request.internalNote || '—';
        document.getElementById('detailStatusWrap').innerHTML = statusBadge(request.status);
        document.getElementById('btnDetailEditStatus').onclick = () => {
            closeDetail();
            openStatus(request.id);
        };

        document.getElementById('modalDetail').classList.add('show');
    }

    function closeDetail() {
        document.getElementById('modalDetail').classList.remove('show');
    }

    function openStatus(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        editingId = id;
        document.getElementById('statusInfo').textContent = 'Demande de : ' + getFullName(request) + ' - ' + getSolutionLabel(request);
        document.getElementById('newStatus').value = request.status;
        document.getElementById('noteField').value = request.internalNote || '';
        document.getElementById('modalStatus').classList.add('show');
    }

    function closeStatus() {
        document.getElementById('modalStatus').classList.remove('show');
        editingId = null;
    }

    async function saveStatus() {
        if (!editingId) return;

        const btn = document.getElementById('btnSaveStatus');
        btn.disabled = true;
        btn.textContent = 'Enregistrement...';

        try {
            const status = document.getElementById('newStatus').value;
            const internalNote = document.getElementById('noteField').value.trim() || null;
            const res = await fetch('/api/demo-requests/' + editingId + '/status', {
                method: 'PATCH',
                headers: authHeaders(),
                body: JSON.stringify({ status, internalNote })
            });

            if (res.ok) {
                closeStatus();
                await loadDemoRequests();
                await loadSolutionOptions();
            } else {
                alert('Erreur lors de la mise a jour.');
            }
        } catch {
            alert('Erreur reseau.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Enregistrer';
        }
    }

    function openDelete(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        deletingId = id;
        document.getElementById('deleteMsg').innerHTML = `Voulez-vous vraiment supprimer la demande de <strong>${escapeHtml(getFullName(request))}</strong> pour <strong>${escapeHtml(getSolutionLabel(request))}</strong> ?<br><span style="color:#d63031">Cette action est irreversible.</span>`;
        document.getElementById('modalDelete').classList.add('show');
    }

    function closeDelete() {
        document.getElementById('modalDelete').classList.remove('show');
        deletingId = null;
    }

    async function confirmDelete() {
        if (!deletingId) return;

        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled = true;
        btn.textContent = 'Suppression...';

        try {
            const res = await fetch('/api/demo-requests/' + deletingId, {
                method: 'DELETE',
                headers: authHeaders()
            });

            if (res.ok || res.status === 204) {
                closeDelete();
                await loadSolutionOptions();
                await loadDemoRequests();
            } else {
                alert('Erreur lors de la suppression.');
            }
        } catch {
            alert('Erreur reseau.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Supprimer';
        }
    }

    (async function init() {
        await loadSolutionOptions();
        await loadDemoRequests();
    })();
</script>
}
