@{
    ViewData["Title"] = "Rôles";
    ViewData["ActivePage"] = "Roles";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Rôles</h1>
    <p>Gestion des rôles utilisateurs du backoffice</p>
</div>

<div class="card">
    <div class="card-header">
        <h2>Liste des rôles (<span id="roleCount">0</span>)</h2>
        <button class="btn btn-primary btn-sm" onclick="openAddModal()">+ Ajouter un rôle</button>
    </div>
    <table>
        <thead>
            <tr>
                <th>Nom</th>
                <th>Description</th>
                <th>Statut</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="roleTable">
            <tr class="loading-row"><td colspan="5">Chargement...</td></tr>
        </tbody>
    </table>
</div>

<!-- MODAL AJOUTER / MODIFIER -->
<div class="modal-overlay" id="modalForm">
    <div class="modal-box" style="max-width:480px">
        <button class="modal-close-btn" onclick="closeForm()" title="Fermer">✕</button>
        <h3 id="modalTitle">Ajouter un rôle</h3>
        <div id="formError" style="display:none;background:#fff0f0;border:1px solid #ffc5c5;color:#d63031;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px"></div>

        <div class="mfield" style="margin-bottom:14px">
            <label>Nom du rôle *</label>
            <input type="text" id="fName" placeholder="Ex: Administrateur" />
        </div>
        <div class="mfield" style="margin-bottom:14px">
            <label>Description</label>
            <textarea id="fDescription" rows="3" placeholder="Description du rôle..."></textarea>
        </div>
        <div class="mfield" id="isActiveField" style="display:none;margin-bottom:14px">
            <label>Statut</label>
            <select id="fIsActive">
                <option value="true">Actif</option>
                <option value="false">Inactif</option>
            </select>
        </div>
        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeForm()">Annuler</button>
            <button class="btn btn-primary" id="btnSave" onclick="saveRole()">Enregistrer</button>
        </div>
    </div>
</div>

<!-- MODAL SUPPRESSION -->
<div class="modal-overlay" id="modalDelete">
    <div class="modal-box" style="max-width:400px;text-align:center">
        <button class="modal-close-btn" onclick="closeDelete()" title="Fermer">✕</button>
        <h3 style="margin-bottom:8px">Supprimer ce rôle ?</h3>
        <p style="font-size:14px;color:#6b7db3;margin-bottom:24px" id="deleteMsg">Cette action est irréversible.</p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" onclick="confirmDelete()">Supprimer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .modal-close-btn { position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:#6b7db3; line-height:1; padding:4px 8px; border-radius:6px; transition:background 0.2s; }
    .modal-close-btn:hover { background:#f0f4ff; color:#1e2d5a; }
    .modal-box { position:relative; }
    .mfield label { display:block; font-size:12px; font-weight:500; color:#6b7db3; margin-bottom:5px; }
    .mfield input, .mfield textarea, .mfield select {
        width:100%; padding:10px 12px; border:1.5px solid #dce4f5; border-radius:8px;
        font-size:14px; font-family:inherit; outline:none; color:#1e2d5a;
        transition:border-color 0.2s; background:white;
    }
    .mfield input:focus, .mfield textarea:focus, .mfield select:focus { border-color:#00c8d4; }
    .mfield textarea { resize:vertical; }
</style>
<script>
    let editingId  = null;
    let deletingId = null;

    async function loadRoles() {
        try {
            const res   = await fetch('/api/roles', { headers: authHeaders() });
            const roles = await res.json();
            document.getElementById('roleCount').textContent = Array.isArray(roles) ? roles.length : 0;
            if (!Array.isArray(roles) || !roles.length) {
                document.getElementById('roleTable').innerHTML = '<tr class="empty-row"><td colspan="5">Aucun rôle.</td></tr>';
                return;
            }
            document.getElementById('roleTable').innerHTML = roles.map(r => `
                <tr>
                    <td><strong style="color:#1e2d5a">${r.name}</strong></td>
                    <td style="color:#6b7db3">${r.description || '—'}</td>
                    <td><span class="badge ${r.isActive ? 'badge-success' : 'badge-danger'}">${r.isActive ? 'Actif' : 'Inactif'}</span></td>
                    <td style="color:#6b7db3">${new Date(r.createdAt).toLocaleDateString('fr-FR')}</td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <button class="btn btn-outline btn-sm" onclick="openEditModal(${r.id})">Modifier</button>
                            <button class="btn btn-danger btn-sm" onclick="openDelete(${r.id}, '${r.name}')">Supprimer</button>
                        </div>
                    </td>
                </tr>`).join('');
        } catch(e) {
            document.getElementById('roleTable').innerHTML = '<tr class="empty-row"><td colspan="5">Erreur de chargement.</td></tr>';
        }
    }

    function openAddModal() {
        editingId = null;
        document.getElementById('modalTitle').textContent = 'Ajouter un rôle';
        document.getElementById('fName').value        = '';
        document.getElementById('fDescription').value = '';
        document.getElementById('isActiveField').style.display = 'none';
        document.getElementById('formError').style.display     = 'none';
        document.getElementById('modalForm').classList.add('show');
    }

    async function openEditModal(id) {
        editingId = id;
        document.getElementById('modalTitle').textContent = 'Modifier un rôle';
        document.getElementById('formError').style.display = 'none';
        document.getElementById('isActiveField').style.display = '';
        try {
            const res  = await fetch(`/api/roles/${id}`, { headers: authHeaders() });
            const role = await res.json();
            document.getElementById('fName').value        = role.name;
            document.getElementById('fDescription').value = role.description || '';
            document.getElementById('fIsActive').value    = role.isActive ? 'true' : 'false';
        } catch(e) { console.error(e); }
        document.getElementById('modalForm').classList.add('show');
    }

    function closeForm() { document.getElementById('modalForm').classList.remove('show'); }

    async function saveRole() {
        const name        = document.getElementById('fName').value.trim();
        const description = document.getElementById('fDescription').value.trim();
        const isActive    = document.getElementById('fIsActive').value === 'true';
        const errDiv      = document.getElementById('formError');

        if (!name) { errDiv.textContent = 'Le nom est obligatoire.'; errDiv.style.display = 'block'; return; }
        document.getElementById('btnSave').disabled = true;
        try {
            const body = editingId
                ? { id: editingId, name, description, isActive }
                : { id: 0, name, description, isActive: true };

            const res = await fetch('/api/roles', {
                method: 'POST',
                headers: { ...authHeaders(), 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            if (res.ok) { closeForm(); loadRoles(); }
            else {
                const data = await res.json();
                errDiv.textContent = data.message || 'Erreur.';
                errDiv.style.display = 'block';
            }
        } catch(e) { errDiv.textContent = 'Erreur réseau.'; errDiv.style.display = 'block'; }
        document.getElementById('btnSave').disabled = false;
    }

    function openDelete(id, name) {
        deletingId = id;
        document.getElementById('deleteMsg').textContent = `Supprimer le rôle "${name}" ?`;
        document.getElementById('modalDelete').classList.add('show');
    }
    function closeDelete() { document.getElementById('modalDelete').classList.remove('show'); }

    async function confirmDelete() {
        try {
            await fetch(`/api/roles/${deletingId}`, { method: 'DELETE', headers: authHeaders() });
            closeDelete(); loadRoles();
        } catch(e) { console.error(e); }
    }

    loadRoles();
</script>
}
