@{
    ViewData["Title"] = "Demandes de Packs Personnalises";
    ViewData["ActivePage"] = "CustomPackRequests";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Demandes de Packs Personnalises</h1>
    <p>Suivez les demandes sur mesure envoyees depuis la page publique Nos Packs.</p>
</div>

<div class="card">
    <div class="card-header">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <h2>Liste des demandes (<span id="requestCount">0</span>)</h2>
            <select id="filterSolution" onchange="loadRequests()">
                <option value="">Toutes les solutions</option>
            </select>
            <select id="filterStatus" onchange="loadRequests()">
                <option value="">Tous les statuts</option>
                <option value="Nouvelle">Nouvelle</option>
                <option value="EnCours">En cours</option>
                <option value="Acceptee">Acceptee</option>
                <option value="Refusee">Refusee</option>
            </select>
            <input type="text" id="searchInput" placeholder="Rechercher contact, entreprise ou solution..." oninput="applySearch()" />
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Solution</th>
                <th>Contact</th>
                <th>Entreprise</th>
                <th>Coordonnees</th>
                <th>Fonctionnalites</th>
                <th>Soumise le</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="requestsTable">
            <tr class="loading-row"><td colspan="8">Chargement...</td></tr>
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="detailModal" onclick="if(event.target===this)closeDetail()">
    <div class="modal-box" style="max-width:620px">
        <h3 style="margin-bottom:6px">Detail de la demande</h3>
        <p id="detailSolution" style="font-size:12px;color:#6b7db3;margin-bottom:16px"></p>

        <div class="detail-grid">
            <div><div class="detail-label">Nom</div><div id="detailContact" class="detail-value"></div></div>
            <div><div class="detail-label">Entreprise</div><div id="detailCompany" class="detail-value"></div></div>
            <div><div class="detail-label">Email</div><div id="detailEmail" class="detail-value"></div></div>
            <div><div class="detail-label">Telephone</div><div id="detailPhone" class="detail-value"></div></div>
        </div>

        <div style="margin-bottom:14px">
            <div class="detail-label">Message</div>
            <div id="detailMessage" class="detail-box"></div>
        </div>

        <div style="margin-bottom:14px">
            <div class="detail-label">Fonctionnalites selectionnees</div>
            <div id="detailFeatures" class="feature-list"></div>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;border-top:1px solid #dce4f5;padding-top:14px">
            <div id="detailStatus"></div>
            <div style="display:flex;gap:8px">
                <button class="btn btn-outline" onclick="closeDetail()">Fermer</button>
                <button class="btn btn-primary btn-sm" id="btnOpenStatus">Modifier le statut</button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="statusModal" onclick="if(event.target===this)closeStatus()">
    <div class="modal-box" style="max-width:460px">
        <h3>Mettre a jour la demande</h3>
        <p id="statusInfo" style="font-size:13px;color:#6b7db3;margin-bottom:18px;padding:10px 14px;background:#f8faff;border-radius:8px;border-left:3px solid #00c8d4"></p>
        <div class="mfield" style="margin-bottom:14px">
            <label>Nouveau statut</label>
            <select id="newStatus">
                <option value="Nouvelle">Nouvelle</option>
                <option value="EnCours">En cours</option>
                <option value="Acceptee">Acceptee</option>
                <option value="Refusee">Refusee</option>
            </select>
        </div>
        <div class="mfield" style="margin-bottom:18px">
            <label>Note interne</label>
            <textarea id="noteField" rows="4" placeholder="Note interne..."></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeStatus()">Annuler</button>
            <button class="btn btn-primary" id="btnSaveStatus" onclick="saveStatus()">Enregistrer</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box" style="max-width:420px;text-align:center">
        <h3 style="margin-bottom:8px">Supprimer cette demande ?</h3>
        <p id="deleteMessage" style="font-size:14px;color:#6b7db3;margin-bottom:24px"></p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">Supprimer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    #searchInput,
    #filterSolution,
    #filterStatus,
    .mfield select,
    .mfield textarea {
        padding: 8px 12px;
        border: 1.5px solid #dce4f5;
        border-radius: 8px;
        font-size: 13px;
        color: #1e2d5a;
        font-family: 'Inter', sans-serif;
        outline: none;
        background: white;
    }

    #searchInput {
        min-width: 260px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 14px;
    }

    .detail-label {
        font-size: 11px;
        font-weight: 600;
        color: #6b7db3;
        margin-bottom: 4px;
    }

    .detail-value {
        font-size: 13px;
        color: #1e2d5a;
        white-space: pre-wrap;
    }

    .detail-box {
        font-size: 13px;
        color: #1e2d5a;
        background: #f8faff;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #dce4f5;
        min-height: 56px;
        white-space: pre-wrap;
    }

    .feature-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .feature-chip {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        color: #008a91;
        background: rgba(0,200,212,0.12);
    }

    .badge-nouvelle { background: #e3f2fd; color: #1565c0; }
    .badge-encours { background: #fff3e0; color: #e65100; }
    .badge-acceptee { background: #e8f5e9; color: #2e7d32; }
    .badge-refusee { background: #ffebee; color: #c62828; }

    @@media (max-width: 900px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    let allRequests = [];
    let editingId = null;
    let deletingId = null;
    let solutionOptions = [];

    function esc(value) {
        if (value === null || value === undefined) return '';
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function fmtDate(value) {
        if (!value) return '—';
        return new Date(value).toLocaleDateString('fr-FR', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function statusBadge(status) {
        const map = {
            'Nouvelle': ['badge-nouvelle', 'Nouvelle'],
            'EnCours': ['badge-encours', 'En cours'],
            'Acceptee': ['badge-acceptee', 'Acceptee'],
            'Refusee': ['badge-refusee', 'Refusee']
        };

        const [cls, label] = map[status] || ['badge-nouvelle', status];
        return `<span class="badge ${cls}">${label}</span>`;
    }

    async function loadSolutionOptions() {
        try {
            const res = await authFetch('/api/custom-pack-requests/general-solutions');
            if (!res.ok) return;
            const data = await res.json();
            solutionOptions = Array.isArray(data) ? data : [];
        } catch {
            solutionOptions = [];
        }

        const filter = document.getElementById('filterSolution');
        const currentValue = filter.value;
        filter.innerHTML = '<option value="">Toutes les solutions</option>' + solutionOptions
            .map(solution => `<option value="${solution.id}">${esc(solution.title)}</option>`)
            .join('');

        if (solutionOptions.some(solution => String(solution.id) === currentValue)) {
            filter.value = currentValue;
        }
    }

    async function loadRequests() {
        const params = new URLSearchParams();
        const solutionId = document.getElementById('filterSolution').value;
        const status = document.getElementById('filterStatus').value;

        if (solutionId) params.set('solutionId', solutionId);
        if (status) params.set('status', status);

        const url = params.toString() ? `/api/custom-pack-requests?${params}` : '/api/custom-pack-requests';
        document.getElementById('requestsTable').innerHTML = '<tr class="loading-row"><td colspan="8">Chargement...</td></tr>';

        try {
            const res = await authFetch(url);
            if (!res.ok) {
                document.getElementById('requestsTable').innerHTML = '<tr class="empty-row"><td colspan="8">Erreur de chargement.</td></tr>';
                return;
            }

            const data = await res.json();
            allRequests = Array.isArray(data) ? data : [];
            document.getElementById('requestCount').textContent = allRequests.length;
            renderTable(allRequests);
        } catch {
            document.getElementById('requestsTable').innerHTML = '<tr class="empty-row"><td colspan="8">Erreur reseau.</td></tr>';
        }
    }

    function applySearch() {
        const query = document.getElementById('searchInput').value.toLowerCase().trim();
        if (!query) {
            renderTable(allRequests);
            return;
        }

        renderTable(allRequests.filter(request =>
            (request.contactName || '').toLowerCase().includes(query) ||
            (request.company || '').toLowerCase().includes(query) ||
            (request.email || '').toLowerCase().includes(query) ||
            (request.solutionTitle || '').toLowerCase().includes(query)));
    }

    function renderTable(list) {
        const table = document.getElementById('requestsTable');
        if (!list.length) {
            table.innerHTML = '<tr class="empty-row"><td colspan="8">Aucune demande.</td></tr>';
            return;
        }

        table.innerHTML = list.map(request => `
            <tr>
                <td style="font-weight:600">${esc(request.solutionTitle)}</td>
                <td>${esc(request.contactName)}</td>
                <td>${esc(request.company)}</td>
                <td>
                    <div><a href="mailto:${esc(request.email)}" style="color:#00c8d4">${esc(request.email)}</a></div>
                    <div style="font-size:11px;color:#6b7db3;margin-top:4px">${esc(request.phone)}</div>
                </td>
                <td>${Array.isArray(request.selectedFeatures) ? request.selectedFeatures.length : 0}</td>
                <td style="white-space:nowrap">${fmtDate(request.submittedAt)}</td>
                <td>${statusBadge(request.status)}</td>
                <td>
                    <div style="display:flex;gap:5px;flex-wrap:wrap">
                        <button class="btn btn-outline btn-sm" onclick="openDetail(${request.id})">Detail</button>
                        <button class="btn btn-outline btn-sm" style="border-color:#00c8d4;color:#00c8d4" onclick="openStatus(${request.id})">Statut</button>
                        <button class="btn btn-danger btn-sm" onclick="openDelete(${request.id})">Supprimer</button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function openDetail(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        document.getElementById('detailSolution').textContent = 'Solution : ' + (request.solutionTitle || '—');
        document.getElementById('detailContact').textContent = request.contactName || '—';
        document.getElementById('detailCompany').textContent = request.company || '—';
        document.getElementById('detailEmail').innerHTML = `<a href="mailto:${esc(request.email)}" style="color:#00c8d4">${esc(request.email)}</a>`;
        document.getElementById('detailPhone').textContent = request.phone || '—';
        document.getElementById('detailMessage').textContent = request.message || '—';
        document.getElementById('detailStatus').innerHTML = statusBadge(request.status);
        document.getElementById('detailFeatures').innerHTML = (request.selectedFeatures || [])
            .map(feature => `<span class="feature-chip">${esc(feature)}</span>`)
            .join('');
        document.getElementById('btnOpenStatus').onclick = () => {
            closeDetail();
            openStatus(request.id);
        };
        document.getElementById('detailModal').classList.add('show');
    }

    function closeDetail() {
        document.getElementById('detailModal').classList.remove('show');
    }

    function openStatus(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        editingId = id;
        document.getElementById('statusInfo').textContent = `${request.contactName} - ${request.solutionTitle}`;
        document.getElementById('newStatus').value = request.status;
        document.getElementById('noteField').value = request.internalNote || '';
        document.getElementById('statusModal').classList.add('show');
    }

    function closeStatus() {
        editingId = null;
        document.getElementById('statusModal').classList.remove('show');
    }

    async function saveStatus() {
        if (!editingId) return;

        const btn = document.getElementById('btnSaveStatus');
        btn.disabled = true;
        btn.textContent = 'Enregistrement...';

        try {
            const res = await authFetch(`/api/custom-pack-requests/${editingId}/status`, {
                method: 'PATCH',
                body: JSON.stringify({
                    status: document.getElementById('newStatus').value,
                    internalNote: document.getElementById('noteField').value.trim() || null
                })
            });

            if (res.ok) {
                closeStatus();
                await loadRequests();
            }
        } finally {
            btn.disabled = false;
            btn.textContent = 'Enregistrer';
        }
    }

    function openDelete(id) {
        const request = allRequests.find(item => item.id === id);
        if (!request) return;

        deletingId = id;
        document.getElementById('deleteMessage').innerHTML =
            `Voulez-vous vraiment supprimer la demande de <strong>${esc(request.contactName)}</strong> pour <strong>${esc(request.solutionTitle)}</strong> ?`;
        document.getElementById('deleteModal').classList.add('show');
    }

    function closeDelete() {
        deletingId = null;
        document.getElementById('deleteModal').classList.remove('show');
    }

    async function confirmDelete() {
        if (!deletingId) return;

        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled = true;
        btn.textContent = 'Suppression...';

        try {
            const res = await authFetch('/api/custom-pack-requests/' + deletingId, { method: 'DELETE' });
            if (res.ok || res.status === 204) {
                closeDelete();
                await loadRequests();
            }
        } finally {
            btn.disabled = false;
            btn.textContent = 'Supprimer';
        }
    }

    (async function init() {
        await loadSolutionOptions();
        await loadRequests();
    })();
</script>
}
