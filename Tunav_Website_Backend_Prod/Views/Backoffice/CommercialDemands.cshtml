@{
    ViewData["Title"] = "Demandes Partenaires — Commercial";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
    ViewData["ActivePage"] = "CommercialDemands";
}

<style>
    .modal-close-btn { position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:#6b7db3; line-height:1; padding:4px 8px; border-radius:6px; transition:background 0.2s; }
    .modal-close-btn:hover { background:#f0f4ff; color:#1e2d5a; }
    .modal-box { position:relative; }

    .status-badge { display:inline-flex; padding:2px 10px; border-radius:5px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.4px; }
    .s-nouvelle      { background:#e8f0fe; color:#1a56cc; }
    .s-entraitement  { background:#fef3cd; color:#a05a00; }
    .s-acceptee      { background:#d4edda; color:#1a5c33; }
    .s-refusee       { background:#fde8e8; color:#991b1b; }
    .s-cloturee      { background:#f0f0f0; color:#555; }

    .type-badge { display:inline-flex; padding:2px 10px; border-radius:5px; font-size:11px; font-weight:600; background:#e8f4f8; color:#0e6080; text-transform:uppercase; letter-spacing:.4px; }

    .detail-block { background:#f8faff; border:1px solid #dce4f5; border-radius:8px; padding:14px 16px; margin-bottom:16px; }
    .detail-label { font-size:11px; font-weight:600; color:#6b7db3; text-transform:uppercase; letter-spacing:.5px; margin-bottom:4px; }
    .detail-value { font-size:13px; color:#1e2d5a; line-height:1.55; white-space:pre-wrap; }

    /* ── Modal Détails (read-only) ── */
    .detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px 16px; background:#f8faff; border:1px solid #dce4f5; border-radius:8px; padding:14px 16px; margin-bottom:14px; }
    .dg-label { font-size:10px; font-weight:700; color:#6b7db3; text-transform:uppercase; letter-spacing:.5px; margin-bottom:2px; }
    .dg-value { font-size:13px; color:#1e2d5a; font-weight:500; }
    .dg-full  { grid-column:1/-1; }
    .detail-desc-wrap { margin-bottom:12px; }
    .detail-desc-wrap .dg-label { margin-bottom:6px; }
    .detail-desc-text { font-size:13px; color:#1e2d5a; line-height:1.65; background:#f8faff; border:1px solid #dce4f5; border-radius:8px; padding:12px 14px; white-space:pre-wrap; max-height:160px; overflow-y:auto; }
    .detail-comm-note { padding:10px 12px; background:#f5f7ff; border-left:3px solid #93a8e8; border-radius:0 6px 6px 0; margin-bottom:4px; }
    .detail-comm-note .dg-label { display:block; margin-bottom:4px; }
    .detail-comm-note p { margin:0; font-size:13px; color:#1e2d5a; line-height:1.55; }
    .eye-btn { background:none; border:none; cursor:pointer; padding:4px 6px; border-radius:6px; color:#6b7db3; transition:color .15s,background .15s; vertical-align:middle; }
    .eye-btn:hover { color:#00c8d4; background:#f0fdfe; }
</style>

<div class="page-header">
    <h1>Demandes Partenaires</h1>
    <p>Traitez les demandes commerciales soumises par les partenaires</p>
</div>

<!-- Stats ──────────────────────────────────────────────────────────────────── -->
<div class="stat-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:24px">
    <div class="stat-card">
        <div class="stat-label">TOTAL</div>
        <div class="stat-value" id="stTotal">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">NOUVELLES</div>
        <div class="stat-value" id="stNew" style="color:#1a56cc">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">EN TRAITEMENT</div>
        <div class="stat-value" id="stProgress" style="color:#a05a00">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">ACCEPTÉES</div>
        <div class="stat-value" id="stAccepted" style="color:#1a5c33">—</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">REFUSÉES</div>
        <div class="stat-value" id="stRefused" style="color:#991b1b">—</div>
    </div>
</div>

<!-- Tableau ─────────────────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-header">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex:1">
            <h2>Liste des demandes (<span id="demandCount">0</span>)</h2>
            <select id="filterStatus" onchange="renderTable()"
                style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                <option value="">Tous les statuts</option>
                <option value="Nouvelle">Nouvelle</option>
                <option value="En traitement">En traitement</option>
                <option value="Acceptée">Acceptée</option>
                <option value="Refusée">Refusée</option>
                <option value="Clôturée">Clôturée</option>
            </select>
            <select id="filterType" onchange="renderTable()"
                style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none">
                <option value="">Tous les types</option>
                <option value="Nouveau client">Nouveau client</option>
                <option value="Démonstration">Démonstration</option>
                <option value="Support commercial">Support commercial</option>
                <option value="Proposition commerciale">Proposition commerciale</option>
                <option value="Autre">Autre</option>
            </select>
            <input type="text" id="searchInput" placeholder="Rechercher partenaire, email, sujet…" oninput="renderTable()"
                style="padding:7px 12px;border:1.5px solid #dce4f5;border-radius:8px;font-size:13px;color:#1e2d5a;outline:none;width:240px" />
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th style="width:50px">#</th>
                <th>Partenaire</th>
                <th style="width:160px">Type</th>
                <th>Sujet</th>
                <th style="width:120px">Statut</th>
                <th style="width:100px">Date</th>
                <th style="width:90px">Actions</th>
            </tr>
        </thead>
        <tbody id="demandsTbody">
            <tr class="loading-row"><td colspan="7">Chargement…</td></tr>
        </tbody>
    </table>
</div>

<!-- Modal Détails (read-only) ───────────────────────────────────────────────── -->
<div class="modal-overlay" id="modalDetail">
    <div class="modal-box" style="max-width:620px;max-height:90vh;overflow-y:auto">
        <button class="modal-close-btn" onclick="document.getElementById('modalDetail').classList.remove('show')" title="Fermer">&#x2715;</button>
        <div id="modalDetailContent"></div>
        <div class="modal-actions" style="margin-top:8px">
            <button class="btn btn-outline" onclick="document.getElementById('modalDetail').classList.remove('show')">Fermer</button>
            <button class="btn btn-primary" id="detailToTreatBtn">Traiter cette demande</button>
        </div>
    </div>
</div>

<!-- Modal Traitement ────────────────────────────────────────────────────────── -->
<div class="modal-overlay" id="modalTreat">
    <div class="modal-box" style="max-width:620px;max-height:90vh;overflow-y:auto">
        <button class="modal-close-btn" onclick="closeTreat()" title="Fermer">&#x2715;</button>
        <h3 id="treatTitle" style="margin-bottom:4px">Traiter la demande</h3>
        <p id="treatMeta" style="font-size:12px;color:#6b7db3;margin-bottom:18px;font-weight:500"></p>

        <div class="detail-block">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
                <span class="type-badge" id="treatType"></span>
            </div>
            <div class="detail-label">Sujet</div>
            <div class="detail-value" id="treatSubject" style="font-weight:700;font-size:14px;color:#1e2d5a;margin-bottom:12px"></div>
            <div class="detail-label">Description</div>
            <div class="detail-value" id="treatDesc"></div>
        </div>

        <div class="modal-field">
            <label>Partenaire</label>
            <input type="text" id="treatPartner" readonly
                style="background:#f8faff;color:#6b7db3;width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Inter',sans-serif;outline:none;box-sizing:border-box" />
        </div>
        <div class="modal-field">
            <label>Changer le statut</label>
            <select id="treatStatus"
                style="width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Inter',sans-serif;outline:none;color:var(--text)">
                <option value="Nouvelle">Nouvelle</option>
                <option value="En traitement">En traitement — prise en charge</option>
                <option value="Acceptée">Acceptée</option>
                <option value="Refusée">Refusée</option>
                <option value="Clôturée">Clôturée</option>
            </select>
        </div>
        <div class="modal-field">
            <label>Note commerciale <span style="font-size:11px;font-weight:400;color:#6b7db3">(visible par le partenaire)</span></label>
            <textarea id="treatNote" rows="4" maxlength="1000"
                placeholder="Expliquez votre décision, prochaines étapes, contact commercial…"
                style="width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Inter',sans-serif;outline:none;resize:vertical;color:var(--text)"></textarea>
        </div>
        <div id="treatError" style="display:none;padding:10px 14px;background:#fde8e8;border-radius:8px;color:#991b1b;font-size:13px;margin-bottom:12px"></div>
        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeTreat()">Annuler</button>
            <button class="btn btn-primary" id="treatSaveBtn" onclick="saveTreat()">Enregistrer</button>
        </div>
    </div>
</div>

<script>
const API = '/api/partner-portal/demands';
let allDemands = [];
let treating   = null;

async function loadDemands() {
    try {
        const res = await authFetch(API);
        if (!res.ok) throw new Error();
        const data = await res.json();
        allDemands = data.items ?? data;
        updateStats();
        renderTable();
    } catch(e) {
        if (e.message !== 'AUTH_REDIRECT')
            document.getElementById('demandsTbody').innerHTML =
                '<tr class="empty-row"><td colspan="7">Erreur de chargement.</td></tr>';
    }
}

function updateStats() {
    document.getElementById('stTotal').textContent    = allDemands.length;
    document.getElementById('stNew').textContent      = allDemands.filter(d => d.status === 'Nouvelle').length;
    document.getElementById('stProgress').textContent = allDemands.filter(d => d.status === 'En traitement').length;
    document.getElementById('stAccepted').textContent = allDemands.filter(d => d.status === 'Acceptée').length;
    document.getElementById('stRefused').textContent  = allDemands.filter(d => d.status === 'Refusée').length;
}

function renderTable() {
    const status = document.getElementById('filterStatus').value;
    const type   = document.getElementById('filterType').value;
    const search = (document.getElementById('searchInput').value || '').toLowerCase();

    let data = allDemands;
    if (status) data = data.filter(d => d.status === status);
    if (type)   data = data.filter(d => d.demandType === type);
    if (search) data = data.filter(d =>
        (d.subject||'').toLowerCase().includes(search) ||
        (d.partnerUser?.fullName||'').toLowerCase().includes(search) ||
        (d.partnerUser?.email||'').toLowerCase().includes(search) ||
        (d.demandType||'').toLowerCase().includes(search)
    );

    document.getElementById('demandCount').textContent = data.length;
    const tbody = document.getElementById('demandsTbody');
    if (!data.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Aucune demande trouvée.</td></tr>';
        return;
    }
    tbody.innerHTML = data.map(d => {
        const sKey = (d.status||'nouvelle').toLowerCase()
            .replace(/\s+/g,'').normalize('NFD').replace(/[\u0300-\u036f]/g,'');
        const date = new Date(d.createdAt).toLocaleDateString('fr-FR');
        const partner = d.partnerUser?.fullName || 'Partenaire #' + d.userId;
        const noteSnippet = d.commercialNote
            ? `<div style="font-size:11px;color:#6b7db3;margin-top:2px">${escHtml(d.commercialNote.substring(0,60))}${d.commercialNote.length>60?'…':''}</div>`
            : '';
        return `<tr>
            <td style="font-weight:700;color:#6b7db3">#${d.id}</td>
            <td><strong>${escHtml(partner)}</strong></td>
            <td><span class="type-badge">${escHtml(d.demandType||'—')}</span></td>
            <td style="max-width:200px">
                <div style="font-weight:600;font-size:13px">${escHtml(d.subject)}</div>
                ${noteSnippet}
            </td>
            <td><span class="status-badge s-${sKey}">${d.status}</span></td>
            <td style="color:#6b7db3;font-size:12px;white-space:nowrap">${date}</td>
            <td style="white-space:nowrap">
                <button class="eye-btn" onclick='openDetail(${JSON.stringify(d).replace(/'/g,"&#39;")})' title="Voir les détails">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
                <button class="btn btn-sm btn-primary" onclick='openTreat(${JSON.stringify(d).replace(/'/g,"&#39;")})'>Traiter</button>
            </td>
        </tr>`;
    }).join('');
}

function openTreat(d) {
    treating = d;
    const partner = d.partnerUser?.fullName || 'Partenaire #' + d.userId;
    document.getElementById('treatTitle').textContent   = 'Demande #' + d.id;
    document.getElementById('treatMeta').textContent    = partner + ' · ' + new Date(d.createdAt).toLocaleDateString('fr-FR');
    document.getElementById('treatType').textContent    = d.demandType;
    document.getElementById('treatSubject').textContent = d.subject;
    document.getElementById('treatDesc').textContent    = d.description;
    document.getElementById('treatPartner').value       = partner;
    document.getElementById('treatStatus').value        = d.status || 'Nouvelle';
    document.getElementById('treatNote').value          = d.commercialNote || '';
    document.getElementById('treatError').style.display = 'none';
    document.getElementById('modalTreat').classList.add('show');
}

function closeTreat() {
    document.getElementById('modalTreat').classList.remove('show');
    treating = null;
}

async function saveTreat() {
    if (!treating) return;
    const btn = document.getElementById('treatSaveBtn');
    btn.disabled = true; btn.textContent = 'Enregistrement…';
    try {
        const res = await authFetch(`${API}/${treating.id}/treat`, {
            method: 'PATCH',
            body: JSON.stringify({
                status:         document.getElementById('treatStatus').value,
                commercialNote: document.getElementById('treatNote').value.trim()
            })
        });
        if (!res.ok) throw new Error(await res.text());
        closeTreat();
        await loadDemands();
    } catch(e) {
        if (e.message !== 'AUTH_REDIRECT') {
            const err = document.getElementById('treatError');
            err.textContent = e.message || 'Une erreur est survenue.';
            err.style.display = 'block';
        }
    } finally { btn.disabled = false; btn.textContent = 'Enregistrer'; }
}

function escHtml(str) {
    return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function openDetail(d) {
    const fmt = (dt) => dt ? new Date(dt).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
    const sKey = (d.status||'nouvelle').toLowerCase().replace(/\s+/g,'').normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    const partner = d.partnerUser?.fullName || 'Partenaire #' + d.userId;
    const email   = d.partnerUser?.email || '';

    const noteHtml = d.commercialNote
        ? `<div class="detail-comm-note"><span class="dg-label">Note commerciale (visible partenaire)</span><p>${escHtml(d.commercialNote)}</p></div>`
        : '';

    const attachHtml = d.attachmentUrl
        ? `<div><div class="dg-label">Pièce jointe</div><div class="dg-value"><a href="${escHtml(d.attachmentUrl)}" target="_blank" style="color:#00c8d4">Télécharger ↗</a></div></div>`
        : '';

    document.getElementById('modalDetailContent').innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap">
            <h3 style="margin:0;font-size:15px;font-weight:700;color:#1e2d5a;flex:1">Demande #${d.id}</h3>
            <span class="type-badge">${escHtml(d.demandType||'—')}</span>
            <span class="status-badge s-${sKey}">${d.status}</span>
        </div>
        <div class="detail-grid">
            <div class="dg-full">
                <div class="dg-label">Sujet</div>
                <div class="dg-value" style="font-weight:700;font-size:14px">${escHtml(d.subject)}</div>
            </div>
            <div>
                <div class="dg-label">Partenaire</div>
                <div class="dg-value">${escHtml(partner)}</div>
                ${email ? `<div style="font-size:11px;color:#6b7db3">${escHtml(email)}</div>` : ''}
            </div>
            <div>
                <div class="dg-label">Soumis le</div>
                <div class="dg-value">${fmt(d.createdAt)}</div>
            </div>
            ${d.updatedAt ? `<div><div class="dg-label">Mis à jour</div><div class="dg-value">${fmt(d.updatedAt)}</div></div>` : ''}
            ${d.closedAt  ? `<div><div class="dg-label">Clôturée le</div><div class="dg-value">${fmt(d.closedAt)}</div></div>` : ''}
            ${d.assignedTo ? `<div><div class="dg-label">Assignée à</div><div class="dg-value">${escHtml(d.assignedTo.fullName)}</div></div>` : ''}
            ${attachHtml}
        </div>
        <div class="detail-desc-wrap">
            <div class="dg-label">Description</div>
            <div class="detail-desc-text">${escHtml(d.description||'').replace(/\n/g,'<br>')}</div>
        </div>
        ${noteHtml}
    `;
    document.getElementById('detailToTreatBtn').onclick = () => {
        document.getElementById('modalDetail').classList.remove('show');
        openTreat(d);
    };
    document.getElementById('modalDetail').classList.add('show');
}

loadDemands();
</script>
