@{
    ViewData["Title"] = "Gestion des Solutions";
    ViewData["ActivePage"] = "Solutions";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Gestion des Solutions</h1>
    <p>Creez et mettez a jour les solutions visibles sur le site vitrine.</p>
</div>

<div class="card">
    <div class="card-header">
        <div class="sol-toolbar">
            <h2>Solutions (<span id="solutionCount">0</span>)</h2>
            <input id="filterSearch" type="text" placeholder="Rechercher titre ou description..." />
            <select id="filterType" onchange="loadSolutions()">
                <option value="">Tous les types</option>
                <option value="General">General</option>
                <option value="Sectorial">Sectoriel</option>
            </select>
            <select id="filterStatus" onchange="loadSolutions()">
                <option value="">Tous les statuts</option>
                <option value="true">Actives</option>
                <option value="false">Inactives</option>
            </select>
            <select id="filterSector" onchange="loadSolutions()">
                <option value="">Tous les secteurs</option>
            </select>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openAddModal()">+ Ajouter une solution</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Solution</th>
                <th>Type</th>
                <th>Secteurs / Clients</th>
                <th>Details</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="solutionsTable">
            <tr class="loading-row"><td colspan="6">Chargement...</td></tr>
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="modalForm" onclick="if(event.target===this)closeForm()">
    <div class="modal-box">
        <h3 id="modalTitle">Ajouter une solution</h3>

        <div id="formError" class="form-error" style="display:none"></div>

        <div class="form-grid form-grid-2">
            <div class="mfield">
                <label>Titre *</label>
                <input type="text" id="fTitle" placeholder="Ex: TAGIT RFID" />
            </div>
            <div class="mfield">
                <label>Slug public</label>
                <input type="text" id="fSlug" placeholder="Genere automatiquement si vide" />
            </div>
        </div>

        <div class="form-grid form-grid-2">
            <div class="mfield">
                <label>Type *</label>
                <select id="fType" onchange="toggleTypeFields()">
                    <option value="General">General</option>
                    <option value="Sectorial">Sectoriel</option>
                </select>
            </div>
            <div class="mfield" id="baseSolutionField" style="display:none">
                <label>Solution generale de base</label>
                <select id="fBaseSolutionId">
                    <option value="">Aucune inheritance de packs</option>
                </select>
            </div>
        </div>

        <div class="section-title">Presentation Packs</div>
        <div class="form-grid form-grid-2" style="margin-bottom:14px">
            <div class="mfield">
                <label>Icone packs</label>
                <select id="fPackIconKey">
                    <option value="map-pin">Map Pin</option>
                    <option value="zap">Zap</option>
                    <option value="building">Building</option>
                    <option value="tag">Tag</option>
                    <option value="droplet">Droplet</option>
                    <option value="camera">Camera</option>
                </select>
            </div>
            <div class="mfield">
                <label>Theme packs</label>
                <select id="fPackThemeKey">
                    <option value="blue-cyan">Blue / Cyan</option>
                    <option value="yellow-orange">Yellow / Orange</option>
                    <option value="teal-green">Teal / Green</option>
                    <option value="pink-rose">Pink / Rose</option>
                    <option value="sky-cyan">Sky / Cyan</option>
                    <option value="red-pink">Red / Pink</option>
                </select>
            </div>
        </div>

        <div class="mfield" style="margin-bottom:14px">
            <label>Description</label>
            <textarea id="fDescription" rows="4" placeholder="Description de la solution..."></textarea>
        </div>

        <div class="section-title">Image de couverture</div>
        <div class="form-grid form-grid-image">
            <div class="mfield">
                <label>Uploader une image</label>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input type="file" id="fCoverImageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <button type="button" class="btn btn-outline btn-sm" onclick="uploadCoverImage()">Uploader</button>
                </div>
                <div id="coverUploadMsg" class="small-note"></div>
            </div>
            <div class="mfield">
                <label>URL image (auto remplie apres upload)</label>
                <input type="text" id="fCoverImageUrl" placeholder="/uploads/solutions/..." oninput="updateCoverPreview()" />
            </div>
        </div>

        <div class="cover-preview-wrap" id="coverPreviewWrap" style="display:none">
            <img id="coverPreview" alt="Apercu image solution" />
        </div>

        <div class="section-title">Contenu detail</div>
        <div class="mfield" style="margin-bottom:14px">
            <label>URL video YouTube</label>
            <input type="text" id="fYoutubeUrl" placeholder="https://www.youtube.com/watch?v=..." oninput="updateYoutubePreview()" />
        </div>
        <div class="youtube-preview-wrap" id="youtubePreviewWrap" style="display:none">
            <iframe id="youtubePreviewFrame" title="Apercu YouTube" allowfullscreen></iframe>
        </div>

        <div class="section-title">Secteurs et clients</div>
        <div class="mfield" style="margin-bottom:10px">
            <label>Secteurs (une ligne = un secteur)</label>
            <textarea id="fSectors" rows="4" placeholder="Sante&#10;Industrie&#10;Transport maritime"></textarea>
        </div>

        <div class="form-grid form-grid-2">
            <div class="mfield" id="sectorNameField" style="display:none">
                <label>Secteur principal *</label>
                <input type="text" id="fSectorName" list="sectorSuggestions" placeholder="Ex: Sante" />
                <datalist id="sectorSuggestions"></datalist>
            </div>
            <div class="mfield">
                <label>Top clients (une ligne = un client)</label>
                <textarea id="fTopClients" rows="4" placeholder="Monoprix&#10;Carrefour&#10;Leoni Tunisia"></textarea>
            </div>
        </div>

        <div class="section-title">Fonctionnalites et avantages</div>
        <div class="form-grid form-grid-2" style="margin-bottom:14px">
            <div class="mfield">
                <label>Fonctionnalites (une ligne = un item)</label>
                <textarea id="fFunctionalities" rows="5" placeholder="Tags RFID haute performance"></textarea>
            </div>
            <div class="mfield">
                <label>Avantages (une ligne = un item)</label>
                <textarea id="fAdvantages" rows="5" placeholder="Inventaire en temps reel"></textarea>
            </div>
        </div>

        <div class="section-title section-title-flex">
            <span>Cas d'usage</span>
            <button type="button" class="btn btn-outline btn-sm" onclick="addUseCaseRow()">+ Ajouter un cas</button>
        </div>
        <div id="useCasesContainer" class="usecases-list"></div>
        <div class="small-note" style="margin-bottom:14px">
            Chaque cas d'usage contient un titre et une description.
        </div>

        <div class="mfield" id="isActiveField" style="display:none;margin-bottom:12px">
            <label>Statut</label>
            <select id="fIsActive">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </div>

        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeForm()">Annuler</button>
            <button class="btn btn-primary" id="btnSave" onclick="saveSolution()">Enregistrer</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalDelete" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box" style="max-width:420px;text-align:center">
        <div style="width:50px;height:50px;background:#fff0f0;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;color:#d63031;font-size:24px">!</div>
        <h3 style="margin-bottom:8px">Supprimer definitivement cette solution ?</h3>
        <p style="font-size:14px;color:#6b7db3;margin-bottom:8px">
            Voulez-vous supprimer definitivement
            <strong id="deleteName"></strong> ?
        </p>
        <p style="font-size:12px;color:#6b7db3;margin-bottom:24px">
            Cette action supprimera la solution de la base de donnees.
        </p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">Confirmer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .sol-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sol-toolbar input,
    .sol-toolbar select {
        padding: 7px 12px;
        border: 1.5px solid #dce4f5;
        border-radius: 8px;
        font-size: 13px;
        color: #1e2d5a;
        outline: none;
        background: #fff;
    }

    .sol-toolbar input {
        min-width: 250px;
    }

    #modalForm {
        align-items: flex-start;
        overflow-y: auto;
        padding: 24px 12px;
    }

    #modalForm .modal-box {
        width: min(960px, 95vw);
        max-height: calc(100vh - 48px);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        padding: 22px;
    }

    .form-error {
        background: #fff0f0;
        border: 1px solid #ffc5c5;
        color: #d63031;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .section-title {
        font-size: 13px;
        font-weight: 700;
        color: #1e2d5a;
        margin: 14px 0 10px;
    }

    .section-title-flex {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .form-grid {
        display: grid;
        gap: 12px;
    }

    .form-grid-2 {
        grid-template-columns: 1fr 1fr;
        margin-bottom: 14px;
    }

    .form-grid-image {
        grid-template-columns: 1.2fr 1fr;
        margin-bottom: 10px;
    }

    .mfield label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #6b7db3;
        margin-bottom: 5px;
    }

    .mfield input,
    .mfield textarea,
    .mfield select {
        width: 100%;
        padding: 10px 12px;
        border: 1.5px solid #dce4f5;
        border-radius: 8px;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        outline: none;
        color: #1e2d5a;
        transition: border-color .2s;
        background: white;
    }

    .mfield input:focus,
    .mfield textarea:focus,
    .mfield select:focus {
        border-color: #00c8d4;
    }

    .mfield textarea {
        resize: vertical;
    }

    .small-note {
        font-size: 12px;
        color: #6b7db3;
    }

    .cover-preview-wrap {
        margin-bottom: 12px;
        border: 1px solid #dce4f5;
        border-radius: 10px;
        overflow: hidden;
        background: #f8faff;
    }

    .cover-preview-wrap img {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        display: block;
    }

    .youtube-preview-wrap {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 14px;
        background: #000;
    }

    .youtube-preview-wrap iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .sector-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .sector-option {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #dce4f5;
        border-radius: 8px;
        padding: 8px 10px;
        background: #fff;
        font-size: 13px;
        color: #1e2d5a;
    }

    .sector-option input {
        width: 15px;
        height: 15px;
        accent-color: #1a2a6c;
    }

    .usecases-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 8px;
    }

    .usecase-row {
        border: 1px solid #dce4f5;
        border-radius: 10px;
        padding: 10px;
        background: #fbfdff;
    }

    .usecase-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr auto;
        gap: 8px;
        align-items: start;
    }

    .usecase-row input,
    .usecase-row textarea {
        width: 100%;
        padding: 9px 10px;
        border: 1.5px solid #dce4f5;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
    }

    .usecase-row textarea {
        min-height: 68px;
        resize: vertical;
    }

    .remove-case-btn {
        border: 1px solid #ffc5c5;
        color: #d63031;
        background: #fff;
        border-radius: 8px;
        padding: 8px 10px;
        cursor: pointer;
        font-size: 12px;
    }

    .remove-case-btn:hover {
        background: #fff0f0;
    }

    .sol-cell {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .sol-thumb {
        width: 56px;
        height: 42px;
        border-radius: 8px;
        border: 1px solid #dce4f5;
        object-fit: cover;
        background: #f0f4ff;
        flex-shrink: 0;
    }

    .sol-title {
        font-weight: 600;
        color: #1e2d5a;
        max-width: 270px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sol-desc {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-size: 11px;
        color: #6b7db3;
        margin-top: 2px;
        max-width: 270px;
    }

    .badge-type-general {
        background: rgba(26,42,108,.1);
        color: #1a2a6c;
    }

    .badge-type-sectorial {
        background: rgba(0,200,212,.12);
        color: #008a91;
    }

    .mini-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .mini-pill {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
        color: #008a91;
        background: rgba(0,200,212,.12);
    }

    .sector-empty {
        color: #b0bdd8;
        font-size: 12px;
    }

    .detail-kpi {
        display: grid;
        gap: 4px;
        font-size: 11px;
        color: #6b7db3;
    }

    .detail-kpi strong {
        color: #1e2d5a;
    }

    .modal-actions {
        position: sticky;
        bottom: 0;
        background: #fff;
        padding-top: 12px;
        margin-top: 6px;
        border-top: 1px solid #dce4f5;
    }

    @@media (max-width: 900px) {
        .form-grid-2,
        .form-grid-image,
        .usecase-grid {
            grid-template-columns: 1fr;
        }

        .sector-grid {
            grid-template-columns: 1fr;
        }

        .sol-toolbar input {
            min-width: 180px;
        }
    }
</style>

<script>
    let editingId = null;
    let deletingId = null;
    let allowedSectors = [];
    let generalSolutions = [];
    let searchTimer = null;

    function esc(value) {
        if (value === null || value === undefined) return '';
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function parseLines(text) {
        return Array.from(
            new Set(
                (text || '')
                    .split(/\r?\n/)
                    .map(v => v.trim())
                    .filter(Boolean)
            )
        );
    }

    function linesFromList(values) {
        if (!Array.isArray(values)) return '';
        return values.map(v => (v || '').trim()).filter(Boolean).join('\n');
    }

    function typeBadge(type) {
        const cls = type === 'Sectorial' ? 'badge-type-sectorial' : 'badge-type-general';
        const label = type === 'Sectorial' ? 'Sectoriel' : 'General';
        return `<span class="badge ${cls}">${label}</span>`;
    }

    function statusBadge(isActive) {
        return `<span class="badge ${isActive ? 'badge-success' : 'badge-danger'}">${isActive ? 'Active' : 'Inactive'}</span>`;
    }

    function buildSolutionsUrl() {
        const type = document.getElementById('filterType').value;
        const status = document.getElementById('filterStatus').value;
        const sector = document.getElementById('filterSector').value;
        const search = document.getElementById('filterSearch').value.trim();
        const params = new URLSearchParams();

        if (type) params.set('type', type);
        if (status !== '') params.set('isActive', status);
        if (sector) params.set('sector', sector);
        if (search) params.set('search', search);

        const query = params.toString();
        return query ? `/api/solutions?${query}` : '/api/solutions';
    }

    function renderEmptyRow(message) {
        document.getElementById('solutionsTable').innerHTML =
            `<tr class="empty-row"><td colspan="6">${esc(message)}</td></tr>`;
    }

    function renderSectorsList(values) {
        const list = Array.isArray(values) ? values : [];
        if (!list.length) {
            return '<span class="sector-empty">Aucun</span>';
        }

        return `<div class="mini-pills">${list.slice(0, 3).map(s => `<span class="mini-pill">${esc(s)}</span>`).join('')}</div>`;
    }

    function renderSolutionsTable(solutions) {
        const rows = solutions.map(s => {
            const safeTitle = esc(s.title || 'Sans titre');
            const safeDescription = esc(s.description || 'Pas de description');
            const safeDeleteTitle = JSON.stringify(s.title || 'Sans titre');
            const toggleLabel = s.isActive ? 'Desactiver' : 'Activer';
            const toggleClass = s.isActive ? 'btn-outline' : 'btn-primary';
            const thumbUrl = (s.coverImageUrl || '').trim();
            const thumbHtml = thumbUrl
                ? `<img class="sol-thumb" src="${esc(thumbUrl)}" alt="Image solution" />`
                : '<div class="sol-thumb"></div>';

            const sectors = Array.isArray(s.sectors) ? s.sectors : [];
            const clients = Array.isArray(s.topClients) ? s.topClients : [];
            const funcs = Array.isArray(s.functionalities) ? s.functionalities : [];
            const advs = Array.isArray(s.advantages) ? s.advantages : [];
            const useCases = Array.isArray(s.useCases) ? s.useCases : [];

            return `
                <tr>
                    <td>
                        <div class="sol-cell">
                            ${thumbHtml}
                            <div>
                                <div class="sol-title" title="${safeTitle}">${safeTitle}</div>
                                <div class="sol-desc" title="${safeDescription}">${safeDescription}</div>
                            </div>
                        </div>
                    </td>
                    <td>${typeBadge(s.type)}</td>
                    <td>
                        ${renderSectorsList(sectors)}
                        <div style="font-size:11px;color:#6b7db3;margin-top:6px">
                            Top clients: <strong>${clients.length}</strong>
                        </div>
                    </td>
                    <td>
                        <div class="detail-kpi">
                            <span>Fonctionnalites: <strong>${funcs.length}</strong></span>
                            <span>Avantages: <strong>${advs.length}</strong></span>
                            <span>Cas d'usage: <strong>${useCases.length}</strong></span>
                        </div>
                    </td>
                    <td>${statusBadge(!!s.isActive)}</td>
                    <td>
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button class="btn btn-outline btn-sm" onclick="openEditModal(${s.id})">Modifier</button>
                            <button class="btn ${toggleClass} btn-sm" onclick="toggleStatus(${s.id})">${toggleLabel}</button>
                            <button class="btn btn-danger btn-sm" onclick='openDelete(${s.id}, ${safeDeleteTitle})'>Supprimer</button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');

        document.getElementById('solutionsTable').innerHTML = rows;
    }

    async function loadSolutions() {
        try {
            const res = await authFetch(buildSolutionsUrl());
            if (!res.ok) {
                renderEmptyRow(`Erreur lors du chargement (${res.status})`);
                return;
            }

            const data = await res.json();
            const list = Array.isArray(data) ? data : [];
            document.getElementById('solutionCount').textContent = list.length;

            if (!list.length) {
                renderEmptyRow('Aucune solution trouvee.');
                return;
            }

            renderSolutionsTable(list);
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            renderEmptyRow('Erreur reseau lors du chargement.');
        }
    }

    function renderSectorOptions() {
        const filter = document.getElementById('filterSector');
        const currentValue = filter.value;
        const filterOptions = ['<option value="">Tous les secteurs</option>']
            .concat(allowedSectors.map(s => `<option value="${esc(s)}">${esc(s)}</option>`));
        filter.innerHTML = filterOptions.join('');
        filter.value = allowedSectors.includes(currentValue) ? currentValue : '';

        document.getElementById('sectorSuggestions').innerHTML =
            allowedSectors.map(s => `<option value="${esc(s)}"></option>`).join('');
    }

    function renderBaseSolutionOptions() {
        const select = document.getElementById('fBaseSolutionId');
        const currentValue = select.value;
        const options = ['<option value="">Aucune inheritance de packs</option>']
            .concat(generalSolutions
                .filter(solution => !editingId || solution.id !== editingId)
                .map(solution => `<option value="${solution.id}">${esc(solution.title)}${solution.isActive ? '' : ' (inactive)'}</option>`));

        select.innerHTML = options.join('');
        select.value = generalSolutions.some(solution => String(solution.id) === currentValue)
            ? currentValue
            : '';
    }

    function resetUseCases() {
        const container = document.getElementById('useCasesContainer');
        container.innerHTML = '';
    }

    function addUseCaseRow(title = '', description = '') {
        const container = document.getElementById('useCasesContainer');
        const row = document.createElement('div');
        row.className = 'usecase-row';
        row.innerHTML = `
            <div class="usecase-grid">
                <input type="text" class="usecase-title" placeholder="Titre du cas d'usage" />
                <textarea class="usecase-description" placeholder="Description du cas d'usage"></textarea>
                <button type="button" class="remove-case-btn" onclick="removeUseCaseRow(this)">Retirer</button>
            </div>
        `;

        row.querySelector('.usecase-title').value = title || '';
        row.querySelector('.usecase-description').value = description || '';
        container.appendChild(row);
    }

    function removeUseCaseRow(btn) {
        const row = btn.closest('.usecase-row');
        if (row) row.remove();
    }

    function collectUseCases() {
        const rows = Array.from(document.querySelectorAll('#useCasesContainer .usecase-row'));
        const result = [];

        for (const row of rows) {
            const title = (row.querySelector('.usecase-title')?.value || '').trim();
            const description = (row.querySelector('.usecase-description')?.value || '').trim();
            if (!title && !description) continue;
            if (!title) {
                throw new Error("Chaque cas d'usage doit avoir un titre.");
            }
            result.push({ title, description });
        }

        return result;
    }

    function showErr(message) {
        const el = document.getElementById('formError');
        el.textContent = message;
        el.style.display = 'block';
    }

    function clearErr() {
        const el = document.getElementById('formError');
        el.textContent = '';
        el.style.display = 'none';
    }

    function toggleTypeFields() {
        const type = document.getElementById('fType').value;
        document.getElementById('sectorNameField').style.display = type === 'Sectorial' ? 'block' : 'none';
        document.getElementById('baseSolutionField').style.display = type === 'Sectorial' ? 'block' : 'none';
    }

    function resetFormState() {
        document.getElementById('fTitle').value = '';
        document.getElementById('fSlug').value = '';
        document.getElementById('fDescription').value = '';
        document.getElementById('fType').value = 'General';
        document.getElementById('fSectorName').value = '';
        document.getElementById('fBaseSolutionId').value = '';
        document.getElementById('fPackIconKey').value = 'map-pin';
        document.getElementById('fPackThemeKey').value = 'blue-cyan';
        document.getElementById('fSectors').value = '';
        document.getElementById('fTopClients').value = '';
        document.getElementById('fFunctionalities').value = '';
        document.getElementById('fAdvantages').value = '';
        document.getElementById('fCoverImageUrl').value = '';
        document.getElementById('fYoutubeUrl').value = '';
        document.getElementById('fCoverImageFile').value = '';
        document.getElementById('fIsActive').value = 'true';
        document.getElementById('coverUploadMsg').textContent = '';
        resetUseCases();
        addUseCaseRow();
        updateCoverPreview();
        updateYoutubePreview();
        renderBaseSolutionOptions();
        clearErr();
        toggleTypeFields();
    }

    function openAddModal() {
        editingId = null;
        document.getElementById('modalTitle').textContent = 'Ajouter une solution';
        document.getElementById('btnSave').textContent = 'Enregistrer';
        document.getElementById('isActiveField').style.display = 'none';
        resetFormState();
        document.getElementById('modalForm').classList.add('show');
    }

    async function openEditModal(id) {
        editingId = id;
        document.getElementById('modalTitle').textContent = 'Modifier la solution';
        document.getElementById('btnSave').textContent = 'Mettre a jour';
        document.getElementById('isActiveField').style.display = 'block';
        clearErr();

        try {
            const res = await authFetch('/api/solutions/' + id);
            if (!res.ok) {
                showErr('Erreur lors du chargement de la solution.');
                return;
            }

            const s = await res.json();
            document.getElementById('fTitle').value = s.title || '';
            document.getElementById('fSlug').value = s.slug || '';
            document.getElementById('fDescription').value = s.description || '';
            document.getElementById('fType').value = s.type === 'Sectorial' ? 'Sectorial' : 'General';
            renderBaseSolutionOptions();
            document.getElementById('fBaseSolutionId').value = s.baseSolutionId ? String(s.baseSolutionId) : '';
            document.getElementById('fPackIconKey').value = s.packIconKey || 'map-pin';
            document.getElementById('fPackThemeKey').value = s.packThemeKey || 'blue-cyan';
            document.getElementById('fCoverImageUrl').value = s.coverImageUrl || '';
            document.getElementById('fYoutubeUrl').value = s.youtubeUrl || '';
            document.getElementById('fSectors').value = linesFromList(s.sectors);
            document.getElementById('fTopClients').value = linesFromList(s.topClients);
            document.getElementById('fFunctionalities').value = linesFromList(s.functionalities);
            document.getElementById('fAdvantages').value = linesFromList(s.advantages);
            document.getElementById('fIsActive').value = s.isActive ? 'true' : 'false';

            document.getElementById('fSectorName').value = s.sectorName || '';

            resetUseCases();
            const existingUseCases = Array.isArray(s.useCases) ? s.useCases : [];
            if (!existingUseCases.length) {
                addUseCaseRow();
            } else {
                existingUseCases.forEach(u => addUseCaseRow(u.title || '', u.description || ''));
            }

            toggleTypeFields();
            updateCoverPreview();
            updateYoutubePreview();
            document.getElementById('modalForm').classList.add('show');
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            showErr('Erreur reseau lors du chargement.');
        }
    }

    function closeForm() {
        document.getElementById('modalForm').classList.remove('show');
        editingId = null;
    }

    function updateCoverPreview() {
        const url = document.getElementById('fCoverImageUrl').value.trim();
        const wrap = document.getElementById('coverPreviewWrap');
        const img = document.getElementById('coverPreview');
        if (!url) {
            wrap.style.display = 'none';
            img.removeAttribute('src');
            return;
        }
        img.src = url;
        wrap.style.display = 'block';
    }

    async function uploadCoverImage() {
        const fileInput = document.getElementById('fCoverImageFile');
        const msg = document.getElementById('coverUploadMsg');
        const file = fileInput.files && fileInput.files[0];

        msg.textContent = '';
        if (!file) {
            msg.textContent = 'Selectionnez une image avant upload.';
            return;
        }

        const formData = new FormData();
        formData.append('file', file);
        msg.textContent = 'Upload en cours...';

        try {
            const res = await authFetch('/api/uploads/solution-image', {
                method: 'POST',
                body: formData
            });

            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                msg.textContent = data.message || `Erreur upload (${res.status}).`;
                return;
            }

            document.getElementById('fCoverImageUrl').value = data.url || '';
            updateCoverPreview();
            msg.textContent = 'Image uploadee avec succes.';
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            msg.textContent = 'Erreur reseau lors de upload.';
        }
    }

    function getYouTubeEmbedUrl(input) {
        const raw = (input || '').trim();
        if (!raw) return '';
        let id = '';

        try {
            const url = new URL(raw);
            if (url.hostname.includes('youtube.com')) {
                id = url.searchParams.get('v') || '';
                if (!id && url.pathname.startsWith('/embed/')) {
                    id = url.pathname.split('/').pop() || '';
                }
            } else if (url.hostname.includes('youtu.be')) {
                id = url.pathname.replace('/', '');
            }
        } catch {
            return '';
        }

        return id ? `https://www.youtube.com/embed/${encodeURIComponent(id)}` : '';
    }

    function updateYoutubePreview() {
        const url = document.getElementById('fYoutubeUrl').value.trim();
        const embed = getYouTubeEmbedUrl(url);
        const wrap = document.getElementById('youtubePreviewWrap');
        const frame = document.getElementById('youtubePreviewFrame');

        if (!embed) {
            wrap.style.display = 'none';
            frame.removeAttribute('src');
            return;
        }

        frame.src = embed;
        wrap.style.display = 'block';
    }

    async function saveSolution() {
        const btn = document.getElementById('btnSave');
        clearErr();

        const title = document.getElementById('fTitle').value.trim();
        const slug = document.getElementById('fSlug').value.trim();
        const description = document.getElementById('fDescription').value.trim();
        const type = document.getElementById('fType').value;
        const baseSolutionIdValue = document.getElementById('fBaseSolutionId').value;
        const packIconKey = document.getElementById('fPackIconKey').value;
        const packThemeKey = document.getElementById('fPackThemeKey').value;
        const selectedSectors = parseLines(document.getElementById('fSectors').value);
        const selectedPrimary = document.getElementById('fSectorName').value.trim();
        const topClients = parseLines(document.getElementById('fTopClients').value);
        const functionalities = parseLines(document.getElementById('fFunctionalities').value);
        const advantages = parseLines(document.getElementById('fAdvantages').value);
        const coverImageUrl = document.getElementById('fCoverImageUrl').value.trim();
        const youtubeUrl = document.getElementById('fYoutubeUrl').value.trim();

        if (title.length < 3) {
            showErr('Le titre doit contenir au moins 3 caracteres.');
            return;
        }

        let useCases = [];
        try {
            useCases = collectUseCases();
        } catch (validationError) {
            showErr(validationError.message || 'Cas d usage invalide.');
            return;
        }

        let sectorName = null;
        if (type === 'Sectorial') {
            sectorName = selectedPrimary || selectedSectors[0] || null;
            if (!sectorName) {
                showErr('Pour une solution sectorielle, choisissez au moins un secteur.');
                return;
            }
        }

        const payload = {
            title,
            slug: slug || null,
            description,
            type,
            sectorName,
            baseSolutionId: type === 'Sectorial' && baseSolutionIdValue ? Number(baseSolutionIdValue) : null,
            clearBaseSolution: type === 'Sectorial' && !baseSolutionIdValue,
            packIconKey,
            packThemeKey,
            coverImageUrl: coverImageUrl || null,
            youtubeUrl: youtubeUrl || null,
            sectors: selectedSectors,
            topClients,
            functionalities,
            advantages,
            useCases
        };

        const isEdit = editingId !== null;
        if (isEdit) {
            payload.isActive = document.getElementById('fIsActive').value === 'true';
        }

        btn.disabled = true;
        btn.textContent = 'Traitement...';

        try {
            const res = await authFetch(isEdit ? `/api/solutions/${editingId}` : '/api/solutions', {
                method: isEdit ? 'PUT' : 'POST',
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                await loadAllowedSectors();
                closeForm();
                await loadSolutions();
                return;
            }

            const data = await res.json().catch(() => ({}));
            showErr(data.message || `Erreur lors de l'enregistrement (${res.status}).`);
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            showErr('Erreur reseau lors de la sauvegarde.');
        } finally {
            btn.disabled = false;
            btn.textContent = editingId !== null ? 'Mettre a jour' : 'Enregistrer';
        }
    }

    function openDelete(id, name) {
        deletingId = id;
        document.getElementById('deleteName').textContent = name || 'Sans titre';
        document.getElementById('modalDelete').classList.add('show');
    }

    function closeDelete() {
        document.getElementById('modalDelete').classList.remove('show');
        document.getElementById('deleteName').textContent = '';
        deletingId = null;
    }

    async function confirmDelete() {
        if (!deletingId) return;

        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled = true;
        btn.textContent = 'Suppression...';

        try {
            const res = await authFetch('/api/solutions/' + deletingId, { method: 'DELETE' });

            if (res.ok) {
                await loadAllowedSectors();
                closeDelete();
                await loadSolutions();
                return;
            }

            const data = await res.json().catch(() => ({}));
            alert(data.message || 'Erreur lors de la suppression.');
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            alert('Erreur reseau.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Confirmer';
        }
    }

    async function toggleStatus(id) {
        try {
            const res = await authFetch(`/api/solutions/${id}/toggle`, { method: 'PATCH' });

            if (res.ok) {
                await loadSolutions();
                return;
            }

            const data = await res.json().catch(() => ({}));
            alert(data.message || 'Erreur lors du changement de statut.');
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            alert('Erreur reseau.');
        }
    }

    async function loadAllowedSectors() {
        try {
            const res = await authFetch('/api/solutions/sectors');
            if (!res.ok) throw new Error(`status ${res.status}`);
            const data = await res.json();
            allowedSectors = Array.isArray(data) ? data : [];
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            allowedSectors = [];
        }

        renderSectorOptions();
    }

    async function loadGeneralSolutions() {
        try {
            const res = await authFetch('/api/packs/general-solutions');
            if (!res.ok) throw new Error(`status ${res.status}`);
            const data = await res.json();
            generalSolutions = Array.isArray(data) ? data : [];
        } catch (error) {
            if (isAuthInterrupt(error)) return;
            console.error(error);
            generalSolutions = [];
        }

        renderBaseSolutionOptions();
    }

    function onSearchInput() {
        if (searchTimer) clearTimeout(searchTimer);
        searchTimer = setTimeout(loadSolutions, 350);
    }

    (function bindSearch() {
        const searchInput = document.getElementById('filterSearch');
        if (searchInput) {
            searchInput.addEventListener('input', onSearchInput);
        }
    })();

    (async function init() {
        await loadAllowedSectors();
        await loadGeneralSolutions();
        await loadSolutions();
    })();
</script>
}
