@{
    ViewData["Title"] = "Gestion de l'equipe";
    ViewData["ActivePage"] = "Team";
    Layout = "~/Views/Shared/_LayoutBackoffice.cshtml";
}

<div class="page-header">
    <h1>Gestion de l'equipe</h1>
    <p>Ajoutez, modifiez et gerez les membres de l'equipe TUNAV</p>
</div>

<div class="card">
    <div class="card-header">
        <h2>Membres de l'equipe (<span id="memberCount">0</span>)</h2>
        <button class="btn btn-primary btn-sm" onclick="openAddModal()">+ Ajouter un membre</button>
    </div>
    <table>
        <thead>
            <tr>
                <th>Membre</th>
                <th>Poste</th>
                <th>Contact</th>
                <th>Ordre</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="teamTable">
            <tr class="loading-row"><td colspan="6">Chargement...</td></tr>
        </tbody>
    </table>
</div>

<!-- MODAL AJOUTER / MODIFIER -->
<div class="modal-overlay" id="modalForm">
    <div class="modal-box" style="max-width:540px">
        <button class="modal-close-btn" onclick="closeForm()" title="Fermer">✕</button>
        <h3 id="modalTitle">Ajouter un membre</h3>

        <div id="formError" style="display:none;background:#fff0f0;border:1px solid #ffc5c5;color:#d63031;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div class="mfield"><label>Prenom *</label><input type="text" id="fFirstName" placeholder="Mohamed" /></div>
            <div class="mfield"><label>Nom *</label><input type="text" id="fLastName" placeholder="Ben Salem" /></div>
        </div>

        <div class="mfield" style="margin-bottom:14px">
            <label>Poste *</label>
            <input type="text" id="fPosition" placeholder="Ex: Directeur Technique" />
        </div>

        <div class="mfield" style="margin-bottom:14px">
            <label>Description</label>
            <textarea id="fDescription" rows="3" placeholder="Description du membre..."></textarea>
        </div>

        <div class="mfield" style="margin-bottom:14px">
            <label>Photo</label>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:6px">
                <input type="file" id="fPhotoFile" accept=".jpg,.jpeg,.png,.webp" style="font-size:12px;max-width:220px" />
                <button type="button" class="btn btn-outline btn-sm" onclick="uploadTeamPhoto()">Importer sur le serveur</button>
            </div>
            <input type="text" id="fPhotoUrl" placeholder="Ou URL (https://… ou /uploads/…)" />
            <div id="fPhotoUploadMsg" style="font-size:11px;color:#6b7db3;margin-top:4px"></div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
            <div class="mfield">
                <label>LinkedIn</label>
                <input type="text" id="fLinkedIn" placeholder="https://linkedin.com/in/..." />
            </div>
            <div class="mfield">
                <label>Email professionnel</label>
                <input type="email" id="fEmail" placeholder="nom@@tunav.tn" />
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px">
            <div class="mfield">
                <label>Ordre d'affichage</label>
                <input type="number" id="fDisplayOrder" value="0" min="0" />
            </div>
            <div class="mfield" id="isActiveField" style="display:none">
                <label>Statut</label>
                <select id="fIsActive">
                    <option value="true">Actif</option>
                    <option value="false">Inactif</option>
                </select>
            </div>
        </div>

        <div class="modal-actions">
            <button class="btn btn-outline" onclick="closeForm()">Annuler</button>
            <button class="btn btn-primary" id="btnSave" onclick="saveMember()">Enregistrer</button>
        </div>
    </div>
</div>

<!-- MODAL SUPPRESSION -->
<div class="modal-overlay" id="modalDelete">
    <div class="modal-box" style="max-width:400px;text-align:center">
        <button class="modal-close-btn" onclick="closeDelete()" title="Fermer">✕</button>
        <h3 style="margin-bottom:8px">Supprimer ce membre ?</h3>
        <p style="font-size:14px;color:#6b7db3;margin-bottom:24px" id="deleteMsg">Cette action est irreversible.</p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn btn-outline" onclick="closeDelete()">Annuler</button>
            <button class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">Supprimer</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .modal-close-btn { position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:#6b7db3; line-height:1; padding:4px 8px; border-radius:6px; transition:background 0.2s; }
    .modal-close-btn:hover { background:#f0f4ff; color:#1e2d5a; }
    .modal-box { position:relative; }
    .mfield label { display:block; font-size:12px; font-weight:500; color:#6b7db3; margin-bottom:5px; }
    .mfield input, .mfield textarea, .mfield select {
        width:100%; padding:10px 12px; border:1.5px solid #dce4f5; border-radius:8px;
        font-size:14px; font-family:'Inter',sans-serif; outline:none; color:#1e2d5a;
        transition:border-color 0.2s; background:white;
    }
    .mfield input:focus, .mfield textarea:focus, .mfield select:focus { border-color:#00c8d4; }
    .mfield textarea { resize:vertical; }
    .member-av {
        width:38px; height:38px; border-radius:50%; background:#00c8d4;
        display:flex; align-items:center; justify-content:center;
        font-size:13px; font-weight:700; color:#0d1b4b; flex-shrink:0;
    }
    .social-link {
        display:inline-flex; align-items:center; gap:4px;
        font-size:11px; font-weight:500; padding:3px 8px;
        border-radius:6px; text-decoration:none; transition:opacity 0.15s;
    }
    .social-link:hover { opacity:0.8; }
    .social-linkedin { background:#e8f0fe; color:#0a66c2; }
    .social-email    { background:#fce8e6; color:#c5221f; }
</style>
<script>
    let editingId  = null;
    let deletingId = null;

    async function uploadTeamPhoto() {
        const inp = document.getElementById('fPhotoFile');
        const msg = document.getElementById('fPhotoUploadMsg');
        const file = inp && inp.files && inp.files[0];
        if (!file) {
            msg.textContent = 'Choisissez une image.';
            msg.style.color = '#d63031';
            return;
        }
        msg.textContent = 'Envoi en cours...';
        msg.style.color = '#6b7db3';
        const fd = new FormData();
        fd.append('file', file);
        try {
            const res = await authFetch('/api/uploads/team-photo', { method: 'POST', body: fd });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                msg.textContent = data.message || ('Erreur ' + res.status);
                msg.style.color = '#d63031';
                return;
            }
            document.getElementById('fPhotoUrl').value = data.url || '';
            if (inp) inp.value = '';
            msg.textContent = 'Photo enregistrée sur le serveur.';
            msg.style.color = '#00b894';
        } catch (e) {
            if (isAuthInterrupt(e)) return;
            msg.textContent = 'Erreur réseau.';
            msg.style.color = '#d63031';
        }
    }

    // ── LOAD ──────────────────────────────────────────────────────────────────
    async function loadTeam() {
        try {
            const res     = await fetch('/api/team-members', { headers: authHeaders() });
            const members = await res.json();

            document.getElementById('memberCount').textContent = Array.isArray(members) ? members.length : 0;

            if (!Array.isArray(members) || !members.length) {
                document.getElementById('teamTable').innerHTML =
                    '<tr class="empty-row"><td colspan="6">Aucun membre. Cliquez sur "+ Ajouter un membre".</td></tr>';
                return;
            }

            document.getElementById('teamTable').innerHTML = members.map(m => `
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            ${m.photoUrl
                                ? `<img src="${m.photoUrl}" style="width:38px;height:38px;border-radius:50%;object-fit:cover;flex-shrink:0" onerror="this.style.display='none'" />`
                                : `<div class="member-av">${initials(m.firstName, m.lastName)}</div>`
                            }
                            <div>
                                <div style="font-weight:600;color:#1e2d5a">${m.firstName} ${m.lastName}</div>
                                <div style="font-size:11px;color:#6b7db3">${m.createdByName || ''}</div>
                            </div>
                        </div>
                    </td>
                    <td><span class="badge badge-cyan">${m.position}</span></td>
                    <td>
                        <div style="display:flex;flex-direction:column;gap:4px">
                            ${m.linkedInUrl ? `<a href="${m.linkedInUrl}" target="_blank" class="social-link social-linkedin">LinkedIn</a>` : '<span style="font-size:12px;color:#b0bdd8">—</span>'}
                            ${m.email ? `<a href="mailto:${m.email}" class="social-link social-email">${m.email}</a>` : ''}
                        </div>
                    </td>
                    <td style="text-align:center;color:#6b7db3">${m.displayOrder}</td>
                    <td>
                        <span class="badge ${m.isActive ? 'badge-success' : 'badge-danger'}">
                            ${m.isActive ? 'Actif' : 'Inactif'}
                        </span>
                    </td>
                    <td>
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button class="btn btn-outline btn-sm" onclick="openEditModal(${m.id})">Modifier</button>
                            <button class="btn btn-outline btn-sm"
                                style="${m.isActive ? 'border-color:#ffc107;color:#856404' : 'border-color:#00b894;color:#00704a'}"
                                onclick="toggleMember(${m.id})">
                                ${m.isActive ? 'Desactiver' : 'Activer'}
                            </button>
                            <button class="btn btn-danger btn-sm"
                                onclick="openDelete(${m.id}, '${m.firstName} ${m.lastName}')">
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        } catch(e) {
            console.error(e);
            document.getElementById('teamTable').innerHTML =
                '<tr class="empty-row"><td colspan="6">Erreur de chargement.</td></tr>';
        }
    }

    function initials(f, l) { return ((f?.[0] || '') + (l?.[0] || '')).toUpperCase(); }

    // ── OPEN ADD ──────────────────────────────────────────────────────────────
    function openAddModal() {
        editingId = null;
        document.getElementById('modalTitle').textContent  = 'Ajouter un membre';
        document.getElementById('btnSave').textContent     = 'Enregistrer';
        document.getElementById('fFirstName').value        = '';
        document.getElementById('fLastName').value         = '';
        document.getElementById('fPosition').value         = '';
        document.getElementById('fDescription').value      = '';
        document.getElementById('fPhotoUrl').value         = '';
        const pf = document.getElementById('fPhotoFile');
        if (pf) pf.value = '';
        const pm = document.getElementById('fPhotoUploadMsg');
        if (pm) pm.textContent = '';
        document.getElementById('fLinkedIn').value         = '';
        document.getElementById('fEmail').value            = '';
        document.getElementById('fDisplayOrder').value     = '0';
        document.getElementById('isActiveField').style.display = 'none';
        document.getElementById('formError').style.display    = 'none';
        document.getElementById('modalForm').classList.add('show');
    }

    // ── OPEN EDIT ─────────────────────────────────────────────────────────────
    async function openEditModal(id) {
        editingId = id;
        document.getElementById('formError').style.display = 'none';
        document.getElementById('modalTitle').textContent  = 'Modifier un membre';
        document.getElementById('btnSave').textContent     = 'Mettre a jour';

        try {
            const res    = await fetch('/api/team-members/' + id, { headers: authHeaders() });
            const m      = await res.json();
            document.getElementById('fFirstName').value    = m.firstName    || '';
            document.getElementById('fLastName').value     = m.lastName     || '';
            document.getElementById('fPosition').value     = m.position     || '';
            document.getElementById('fDescription').value  = m.description  || '';
            document.getElementById('fPhotoUrl').value     = m.photoUrl     || '';
            const pf = document.getElementById('fPhotoFile');
            if (pf) pf.value = '';
            const pm = document.getElementById('fPhotoUploadMsg');
            if (pm) pm.textContent = '';
            document.getElementById('fLinkedIn').value     = m.linkedInUrl  || '';
            document.getElementById('fEmail').value        = m.email        || '';
            document.getElementById('fDisplayOrder').value = m.displayOrder ?? 0;
            document.getElementById('fIsActive').value     = m.isActive ? 'true' : 'false';
            document.getElementById('isActiveField').style.display = 'block';
            document.getElementById('modalForm').classList.add('show');
        } catch(e) { alert('Erreur lors du chargement.'); }
    }

    function closeForm() {
        document.getElementById('modalForm').classList.remove('show');
        editingId = null;
    }

    // ── SAVE ──────────────────────────────────────────────────────────────────
    async function saveMember() {
        const btn = document.getElementById('btnSave');
        document.getElementById('formError').style.display = 'none';

        const firstName    = document.getElementById('fFirstName').value.trim();
        const lastName     = document.getElementById('fLastName').value.trim();
        const position     = document.getElementById('fPosition').value.trim();
        const description  = document.getElementById('fDescription').value.trim();
        const photoUrl     = document.getElementById('fPhotoUrl').value.trim();
        const linkedInUrl  = document.getElementById('fLinkedIn').value.trim();
        const email        = document.getElementById('fEmail').value.trim();
        const displayOrder = parseInt(document.getElementById('fDisplayOrder').value) || 0;

        if (!firstName) { showErr('Le prenom est obligatoire.');  return; }
        if (!lastName)  { showErr('Le nom est obligatoire.');     return; }
        if (!position)  { showErr('Le poste est obligatoire.');   return; }

        btn.disabled = true;
        btn.textContent = 'Enregistrement...';

        try {
            let url, method, body;

            if (editingId) {
                const isActive = document.getElementById('fIsActive').value === 'true';
                url    = '/api/team-members/' + editingId;
                method = 'PUT';
                body   = { firstName, lastName, position, description,
                           photoUrl: photoUrl || null, linkedInUrl: linkedInUrl || null,
                           email: email || null, displayOrder, isActive };
            } else {
                const u = JSON.parse(localStorage.getItem('tunav_user') || '{}');
                url    = '/api/team-members?userId=' + (u.userId || 1);
                method = 'POST';
                body   = { firstName, lastName, position, description,
                           photoUrl: photoUrl || null, linkedInUrl: linkedInUrl || null,
                           email: email || null, displayOrder };
            }

            const res  = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(body) });
            const data = await res.json();

            if (res.ok) { closeForm(); loadTeam(); }
            else showErr(data.message || 'Erreur lors de l\'enregistrement.');
        } catch(e) {
            showErr('Erreur reseau.');
        } finally {
            btn.disabled = false;
            btn.textContent = editingId ? 'Mettre a jour' : 'Enregistrer';
        }
    }

    // ── TOGGLE ────────────────────────────────────────────────────────────────
    async function toggleMember(id) {
        try {
            const res = await fetch('/api/team-members/' + id + '/toggle', { method: 'PATCH', headers: authHeaders() });
            if (res.ok) loadTeam();
        } catch(e) { alert('Erreur reseau.'); }
    }

    // ── DELETE ────────────────────────────────────────────────────────────────
    function openDelete(id, name) {
        deletingId = id;
        document.getElementById('deleteMsg').textContent =
            'Voulez-vous vraiment supprimer "' + name + '" ? Cette action est irreversible.';
        document.getElementById('modalDelete').classList.add('show');
    }

    function closeDelete() {
        document.getElementById('modalDelete').classList.remove('show');
        deletingId = null;
    }

    async function confirmDelete() {
        if (!deletingId) return;
        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled = true; btn.textContent = 'Suppression...';
        try {
            const res = await fetch('/api/team-members/' + deletingId, { method: 'DELETE', headers: authHeaders() });
            if (res.ok) { closeDelete(); loadTeam(); }
            else alert('Erreur lors de la suppression.');
        } catch(e) { alert('Erreur reseau.'); }
        finally { btn.disabled = false; btn.textContent = 'Supprimer'; }
    }

    function showErr(msg) {
        const el = document.getElementById('formError');
        el.textContent = msg; el.style.display = 'block';
    }

    loadTeam();
</script>
}
