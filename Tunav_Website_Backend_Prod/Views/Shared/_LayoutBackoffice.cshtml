                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "SavClaims" ? "active" : "")" href="@Url.Content("~/backoffice/sav-claims")">Réclamations (SAV)</a>
                </div>
                <div id="nav-commercial-demands-section">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "CommercialDemands" ? "active" : "")" href="@Url.Content("~/backoffice/commercial-demands")">Demandes partenaires (back-office)</a>
                </div>
            </div>
        </nav>
        <div class="sidebar-footer">
            <div class="u-avatar js-initials">AD</div>
            <div>
                <div class="u-name js-name">Admin User</div>
                <div class="u-email js-email"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="650401080c0b2511100b04134b110b">[email&#160;protected]</a></div>
            </div>
            <button class="btn-logout" onclick="logout()">Sortir</button>
        </div>
    </aside>

    <div class="topbar">
        <div class="topbar-title">@ViewData["Title"]</div>
        <div class="profile-wrap" id="profileWrap">
            <div class="profile-btn" onclick="toggleDropdown()">
                <div class="profile-avatar js-initials">AD</div>
                <div>
                    <div class="p-name js-name">Admin User</div>
                    <div class="p-role js-role">Admin</div>
                </div>
                <span class="p-arrow">▾</span>
            </div>
            <div class="dropdown">
                <div class="dd-head">
                    <div class="dd-av js-initials">AD</div>
                    <div>
                        <div class="dd-fullname js-name">Admin User</div>
                        <div class="dd-rolebadge js-role">Admin</div>
                        <div class="dd-mail js-email"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="442520292d2a0430312a25326a302a">[email&#160;protected]</a></div>
                    </div>
                </div>
                <div class="dd-section">
                    <div class="dd-section-title">Mon Profil</div>
                    <div class="dd-item" onclick="openModal('modalProfil')">
                        <div><div class="dd-item-label">Informations personnelles</div><div class="dd-item-sub">Voir votre profil</div></div>
                    </div>
                    <div class="dd-item" onclick="openModal('modalPassword')">
                        <div><div class="dd-item-label">Changer mot de passe</div><div class="dd-item-sub">Securite du compte</div></div>
                    </div>
                </div>
