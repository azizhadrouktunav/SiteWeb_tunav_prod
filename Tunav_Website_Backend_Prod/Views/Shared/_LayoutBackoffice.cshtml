                    <div class="dd-section-title">Gestion Systeme</div>
                    <a class="dd-item" href="@Url.Content("~/backoffice/users")">
                        <div><div class="dd-item-label">Utilisateurs</div><div class="dd-item-sub">Gestion des acces</div></div>
                    </a>
                    <a class="dd-item" href="@Url.Content("~/backoffice/roles")">
                        <div><div class="dd-item-label">Roles et Permissions</div><div class="dd-item-sub">Configuration avancee</div></div>
                    </a>
                </div>
                <div class="dd-section">
                    <div class="dd-item danger" onclick="logout()">
                        <div><div class="dd-item-label">Se deconnecter</div><div class="dd-item-sub">Fermer votre session</div></div>
                    </div>
                </div>
