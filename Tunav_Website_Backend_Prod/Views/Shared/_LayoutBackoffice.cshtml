    <div class="main-content">
        @RenderBody()
    </div>

    <div class="modal-overlay" id="modalProfil" onclick="if(event.target===this)closeModal('modalProfil')">
        <div class="modal-box">
            <h3>Informations personnelles</h3>
            <div class="modal-field"><label>Prenom</label><input type="text" id="mFirstName" readonly /></div>
            <div class="modal-field"><label>Nom</label><input type="text" id="mLastName" readonly /></div>
            <div class="modal-field"><label>Email</label><input type="email" id="mEmail" readonly /></div>
            <div class="modal-field"><label>Role</label><input type="text" id="mRole" readonly /></div>
            <div class="modal-actions">
                <button class="btn btn-outline" onclick="closeModal('modalProfil')">Fermer</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="modalPassword" onclick="if(event.target===this)closeModal('modalPassword')">
        <div class="modal-box">
            <h3>Changer mot de passe</h3>
            <div id="pwMsg" style="display:none;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px"></div>
            <div class="modal-field"><label>Nouveau mot de passe</label><input type="password" id="pwNew" placeholder="Minimum 6 caracteres" /></div>
            <div class="modal-field"><label>Confirmer</label><input type="password" id="pwConfirm" placeholder="Repetez le mot de passe" /></div>
            <div class="modal-actions">
                <button class="btn btn-outline" onclick="closeModal('modalPassword')">Annuler</button>
                <button class="btn btn-primary" onclick="changePassword()">Enregistrer</button>
            </div>
        </div>
    </div>

    <script>
        async function changePassword() {
            const newPw   = document.getElementById('pwNew').value;
            const confirm = document.getElementById('pwConfirm').value;
            if (!newPw || newPw.length < 6) { showPwMsg('Minimum 6 caracteres.', false); return; }
            if (newPw !== confirm)           { showPwMsg('Les mots de passe ne correspondent pas.', false); return; }
            const u = getStoredUser();
            try {
                const res  = await fetch('/api/users/' + u.userId + '/reset-password', {
                    method: 'PATCH', headers: authHeaders(), body: JSON.stringify({ newPassword: newPw })
                });
                const data = await res.json();
                if (res.ok) {
                    showPwMsg('Mot de passe modifie avec succes !', true);
                    document.getElementById('pwNew').value = '';
                    document.getElementById('pwConfirm').value = '';
                } else {
                    showPwMsg(data.message || 'Erreur.', false);
                }
            } catch { showPwMsg('Erreur reseau.', false); }
        }

        function showPwMsg(text, ok) {
            const el = document.getElementById('pwMsg');
            el.textContent = text;
            el.style.display = 'block';
            el.style.background = ok ? '#e6faf0' : '#fff0f0';
            el.style.border     = ok ? '1px solid #b2dfdb' : '1px solid #ffc5c5';
            el.style.color      = ok ? '#00b894' : '#d63031';
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
